# OCR — цепочка fallback: google_vision → claude_cli → tesseract
OCR_CHAIN=google_vision,claude_cli,tesseract

# Google Cloud Vision
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Claude Code CLI мост (используется MAX подписка)
CLAUDE_CLI_PATH=claude

# Пути
INBOX_DIR=./data/inbox
PROCESSED_DIR=./data/processed
FAILED_DIR=./data/failed
DB_PATH=./data/database.sqlite

# API
API_PORT=3000
API_KEY=your-secret-api-key

# Webhook 1С
WEBHOOK_1C_URL=http://server:8080/invoice_exchange/hs/invoices
WEBHOOK_1C_TOKEN=token-for-1c
WEBHOOK_ENABLED=false

# Debug
DEBUG=false
OCR_FORCE_ENGINE=
LOG_LEVEL=info
DRY_RUN=false
