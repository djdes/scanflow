// ========================================================================
// Внешняя обработка: ЗагрузкаНакладныхИзСервиса
// Конфигурация: 1С:УНФ 1.6
// Описание: Загружает распознанные приходные накладные из сервиса 1C-JPGExchange
//           и создаёт документы "ПриходнаяНакладная" в базе 1С
// ========================================================================
//
// Для создания .epf:
// 1. Откройте Конфигуратор 1С
// 2. Файл → Новый → Внешняя обработка
// 3. Укажите имя: "ЗагрузкаНакладныхИзСервиса"
// 4. Создайте форму обработки с реквизитами:
//    - АдресСервиса (Строка) — например "localhost:3000"
//    - APIКлюч (Строка) — ключ из .env API_KEY
//    - ИспользоватьSSL (Булево) — использовать HTTPS
// 5. Вставьте этот код в модуль объекта обработки
// 6. Сохраните как .epf
//
// Подключение в УНФ 1.6:
// Компания → Ещё больше возможностей → Администрирование →
// Печатные формы, отчёты и обработки → Дополнительные отчёты и обработки →
// Создать → указать .epf файл
// ========================================================================

#Область ПрограммныйИнтерфейс

// Основная процедура — загрузка накладных из сервиса
Процедура ЗагрузитьНакладные(АдресСервиса, APIКлюч, ИспользоватьSSL = Ложь) Экспорт

    Попытка
        // 1. Получить список необработанных накладных
        ТекстОтвета = ВыполнитьHTTPЗапрос(АдресСервиса, "/api/invoices/pending", "GET", APIКлюч, ИспользоватьSSL);

        Если ТекстОтвета = Неопределено Тогда
            Сообщить("Ошибка: не удалось получить данные с сервиса");
            Возврат;
        КонецЕсли;

        // 2. Разобрать JSON
        ЧтениеJSON = Новый ЧтениеJSON;
        ЧтениеJSON.УстановитьСтроку(ТекстОтвета);
        Ответ = ПрочитатьJSON(ЧтениеJSON);
        ЧтениеJSON.Закрыть();

        МассивНакладных = Ответ.data;

        Если МассивНакладных.Количество() = 0 Тогда
            Сообщить("Новых накладных нет");
            Возврат;
        КонецЕсли;

        Сообщить("Найдено накладных: " + МассивНакладных.Количество());

        // 3. Обработать каждую накладную
        Для Каждого ДанныеНакладной Из МассивНакладных Цикл
            Попытка
                СоздатьПриходнуюНакладную(ДанныеНакладной);

                // 4. Подтвердить обработку
                ВыполнитьHTTPЗапрос(
                    АдресСервиса,
                    "/api/invoices/" + Формат(ДанныеНакладной.id, "ЧГ=0") + "/confirm",
                    "POST",
                    APIКлюч,
                    ИспользоватьSSL
                );

                Сообщить("Накладная загружена: " + ДанныеНакладной.invoice_number);
            Исключение
                Сообщить("Ошибка при загрузке накладной " + ДанныеНакладной.invoice_number + ": " + ОписаниеОшибки());
            КонецПопытки;
        КонецЦикла;

        Сообщить("Загрузка завершена");

    Исключение
        Сообщить("Критическая ошибка: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедуры

// Выполнение HTTP-запроса к сервису
Функция ВыполнитьHTTPЗапрос(АдресСервиса, Путь, Метод, APIКлюч, ИспользоватьSSL = Ложь)

    Попытка
        // Разбор адреса (хост:порт)
        ЧастиАдреса = СтрРазделить(АдресСервиса, ":");
        Хост = ЧастиАдреса[0];
        Порт = ?(ЧастиАдреса.Количество() > 1, Число(ЧастиАдреса[1]), ?(ИспользоватьSSL, 443, 80));

        Если ИспользоватьSSL Тогда
            ЗащищённоеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
            Соединение = Новый HTTPСоединение(Хост, Порт, , , , 30, ЗащищённоеСоединение);
        Иначе
            Соединение = Новый HTTPСоединение(Хост, Порт, , , , 30);
        КонецЕсли;

        Запрос = Новый HTTPЗапрос(Путь);
        Запрос.Заголовки.Вставить("X-API-Key", APIКлюч);
        Запрос.Заголовки.Вставить("Content-Type", "application/json");

        Если ВРег(Метод) = "GET" Тогда
            Ответ = Соединение.Получить(Запрос);
        ИначеЕсли ВРег(Метод) = "POST" Тогда
            Запрос.УстановитьТелоИзСтроки("{}");
            Ответ = Соединение.ОтправитьДляОбработки(Запрос);
        КонецЕсли;

        Если Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300 Тогда
            Возврат Ответ.ПолучитьТелоКакСтроку("UTF-8");
        Иначе
            Сообщить("HTTP ошибка " + Ответ.КодСостояния + ": " + Ответ.ПолучитьТелоКакСтроку("UTF-8"));
            Возврат Неопределено;
        КонецЕсли;

    Исключение
        Сообщить("Ошибка HTTP-запроса: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

// Создание документа "ПриходнаяНакладная"
Процедура СоздатьПриходнуюНакладную(ДанныеНакладной)

    НовыйДок = Документы.ПриходнаяНакладная.СоздатьДокумент();

    // Шапка документа
    НовыйДок.Дата = ТекущаяДата();

    Если ДанныеНакладной.Свойство("invoice_date") И ЗначениеЗаполнено(ДанныеНакладной.invoice_date) Тогда
        Попытка
            НовыйДок.Дата = Дата(
                СтрЗаменить(ДанныеНакладной.invoice_date, "-", "")
            );
        Исключение
            // Оставляем текущую дату
        КонецПопытки;
    КонецЕсли;

    // Контрагент (поставщик)
    Если ДанныеНакладной.Свойство("supplier") И ЗначениеЗаполнено(ДанныеНакладной.supplier) Тогда
        НовыйДок.Контрагент = НайтиИлиСоздатьКонтрагента(ДанныеНакладной.supplier);
    КонецЕсли;

    // Организация — берём основную
    НовыйДок.Организация = ПараметрыСеанса.ОсновнаяОрганизация;

    // Товары (табличная часть "Запасы")
    Если ДанныеНакладной.Свойство("items") Тогда
        Для Каждого ТоварДанные Из ДанныеНакладной.items Цикл

            НоваяСтрока = НовыйДок.Запасы.Добавить();

            // Номенклатура
            НазваниеТовара = "";
            Если ТоварДанные.Свойство("mapped_name") И ЗначениеЗаполнено(ТоварДанные.mapped_name) Тогда
                НазваниеТовара = ТоварДанные.mapped_name;
            ИначеЕсли ТоварДанные.Свойство("name") Тогда
                НазваниеТовара = ТоварДанные.name;
            КонецЕсли;

            НоваяСтрока.Номенклатура = НайтиИлиСоздатьНоменклатуру(НазваниеТовара);

            // Количество
            Если ТоварДанные.Свойство("quantity") И ЗначениеЗаполнено(ТоварДанные.quantity) Тогда
                НоваяСтрока.Количество = Число(ТоварДанные.quantity);
            КонецЕсли;

            // Цена
            Если ТоварДанные.Свойство("price") И ЗначениеЗаполнено(ТоварДанные.price) Тогда
                НоваяСтрока.Цена = Число(ТоварДанные.price);
            КонецЕсли;

            // Сумма
            Если ТоварДанные.Свойство("total") И ЗначениеЗаполнено(ТоварДанные.total) Тогда
                НоваяСтрока.Сумма = Число(ТоварДанные.total);
            Иначе
                НоваяСтрока.Сумма = НоваяСтрока.Количество * НоваяСтрока.Цена;
            КонецЕсли;

        КонецЦикла;
    КонецЕсли;

    // Записать и провести
    НовыйДок.Записать(РежимЗаписиДокумента.Проведение);

КонецПроцедуры

// Поиск или создание контрагента
Функция НайтиИлиСоздатьКонтрагента(Наименование)

    // Поиск по наименованию
    Контрагент = Справочники.Контрагенты.НайтиПоНаименованию(Наименование, Истина);

    Если Контрагент.Пустая() Тогда
        // Создаём нового контрагента
        НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
        НовыйКонтрагент.Наименование = Наименование;
        НовыйКонтрагент.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
        НовыйКонтрагент.Поставщик = Истина;
        НовыйКонтрагент.Записать();

        Контрагент = НовыйКонтрагент.Ссылка;
        Сообщить("Создан новый контрагент: " + Наименование);
    КонецЕсли;

    Возврат Контрагент;

КонецФункции

// Поиск или создание номенклатуры
Функция НайтиИлиСоздатьНоменклатуру(Наименование)

    // Поиск по наименованию
    Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Истина);

    Если Номенклатура.Пустая() Тогда
        // Создаём новую номенклатуру
        НоваяНоменклатура = Справочники.Номенклатура.СоздатьЭлемент();
        НоваяНоменклатура.Наименование = Наименование;
        НоваяНоменклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас;
        НоваяНоменклатура.Записать();

        Номенклатура = НоваяНоменклатура.Ссылка;
        Сообщить("Создана новая номенклатура: " + Наименование);
    КонецЕсли;

    Возврат Номенклатура;

КонецФункции

#КонецОбласти
