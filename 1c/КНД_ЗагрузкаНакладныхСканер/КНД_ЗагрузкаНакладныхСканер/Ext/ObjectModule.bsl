////////////////////////////////////////////////////////////////////////////////
// ВНЕШНЯЯ ОБРАБОТКА: Загрузка накладных со сканера (scan.magday.ru)
// Для 1С:УНФ 1.6
//
// Получает распознанные приходные накладные из JPGExchange-сервиса
// и создаёт документы "Приходная накладная" с заполненной табличной
// частью "Запасы", автоматическим поиском/созданием контрагентов и
// номенклатуры.
//
// Адрес сервиса и API-ключ хардкодятся константами в начале модуля
// (см. функции КОНСТ_*). Если нужно поменять — правь тут и пересохрани .epf.
////////////////////////////////////////////////////////////////////////////////

// ============================================================================
// КОНСТАНТЫ — правь эти значения при смене API-ключа или адреса сервиса
// ============================================================================

Функция КОНСТ_АдресСервиса()
	Возврат "scan.magday.ru";
КонецФункции

Функция КОНСТ_Порт()
	Возврат 80;
КонецФункции

Функция КОНСТ_ИспользоватьSSL()
	Возврат Ложь;
КонецФункции

Функция КОНСТ_КлючAPI()
	Возврат "your-secret-api-key";
КонецФункции

// ============================================================================
// РЕГИСТРАЦИЯ ОБРАБОТКИ
// ============================================================================

Функция СведенияОВнешнейОбработке() Экспорт

	ПараметрыРегистрации = Новый Структура;
	ПараметрыРегистрации.Вставить("Вид", "ДополнительнаяОбработка");
	ПараметрыРегистрации.Вставить("Наименование", "Загрузка накладных со сканера (JPGExchange)");
	ПараметрыРегистрации.Вставить("Версия", "1.0");
	ПараметрыРегистрации.Вставить("БезопасныйРежим", Ложь);
	ПараметрыРегистрации.Вставить("Информация",
		"Получает распознанные приходные накладные с сервиса scan.magday.ru "
		+ "и создаёт на их основе документы Приходная накладная в 1С:УНФ. "
		+ "Автоматически находит или создаёт контрагентов (по ИНН, имени) и "
		+ "номенклатуру. После успешного создания отправляет подтверждение "
		+ "на сервис, чтобы накладная больше не попадала в очередь загрузки.");
	ПараметрыРегистрации.Вставить("ВерсияБСП", "1.2.1.4");

	ТаблицаКоманд = ПолучитьТаблицуКоманд();
	ДобавитьКоманду(ТаблицаКоманд,
		"Загрузить накладные со сканера",
		"КНД_ЗагрузкаНакладныхСканер",
		"ВызовСерверногоМетода");
	ДобавитьКоманду(ТаблицаКоманд,
		"Выгрузить номенклатуру на сайт",
		"КНД_ВыгрузкаНоменклатуры",
		"ВызовСерверногоМетода");
	ПараметрыРегистрации.Вставить("Команды", ТаблицаКоманд);

	Возврат ПараметрыРегистрации;

КонецФункции

Функция ПолучитьТаблицуКоманд()

	Команды = Новый ТаблицаЗначений;
	Команды.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("Использование", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("ПоказыватьОповещение", Новый ОписаниеТипов("Булево"));
	Команды.Колонки.Добавить("Модификатор", Новый ОписаниеТипов("Строка"));

	Возврат Команды;

КонецФункции

Процедура ДобавитьКоманду(ТаблицаКоманд, Представление, Идентификатор, Использование,
	ПоказыватьОповещение = Ложь, Модификатор = "")

	НоваяКоманда = ТаблицаКоманд.Добавить();
	НоваяКоманда.Представление = Представление;
	НоваяКоманда.Идентификатор = Идентификатор;
	НоваяКоманда.Использование = Использование;
	НоваяКоманда.ПоказыватьОповещение = ПоказыватьОповещение;
	НоваяКоманда.Модификатор = Модификатор;

КонецПроцедуры

Процедура ВыполнитьКоманду(ИдентификаторКоманды, ПараметрыВыполненияКоманды) Экспорт

	Если ИдентификаторКоманды = "КНД_ЗагрузкаНакладныхСканер" Тогда
		// Результат функции игнорируется — отчёт уже записан в Журнал регистрации
		// и продублирован в окно сообщений внутри СоздатьОтчётСтроку().
		ЗагрузитьНакладныеСоСканера();
	ИначеЕсли ИдентификаторКоманды = "КНД_ВыгрузкаНоменклатуры" Тогда
		ВыгрузитьНоменклатуруНаСайт();
	КонецЕсли;

КонецПроцедуры

// ============================================================================
// ОСНОВНАЯ ПРОЦЕДУРА: загрузка накладных со сканера
// ============================================================================

// Главная процедура. Возвращает итоговый отчёт в виде одной многострочной
// строки — чтобы форма могла показать его через ПоказатьПредупреждение,
// а при запуске через "Дополнительную обработку → Выполнить" — записать в
// Журнал регистрации. Это гарантирует что пользователь увидит результат.
Функция ЗагрузитьНакладныеСоСканера() Экспорт

	Отчёт = Новый Массив;
	Отчёт.Добавить("=== Загрузка накладных со сканера ===");
	Отчёт.Добавить("Сервер: " + КОНСТ_АдресСервиса() + ":" + Строка(КОНСТ_Порт()));
	Отчёт.Добавить("");

	// =========================================================================
	// ШАГ 1: GET /api/invoices/pending
	// =========================================================================

	Соединение = СоздатьHTTPСоединение();
	Если Соединение = Неопределено Тогда
		Отчёт.Добавить("✗ Не удалось создать HTTP-соединение с сервером");
		Отчёт.Добавить("Проверь: доступность " + КОНСТ_АдресСервиса() + " из 1С (firewall, DNS)");
		Возврат СоздатьОтчётСтроку(Отчёт);
	КонецЕсли;

	Запрос = Новый HTTPЗапрос("/api/invoices/pending");
	Запрос.Заголовки.Вставить("X-API-Key", КОНСТ_КлючAPI());
	Запрос.Заголовки.Вставить("Accept", "application/json");

	Попытка
		Ответ = Соединение.Получить(Запрос);
	Исключение
		Отчёт.Добавить("✗ Ошибка GET /api/invoices/pending:");
		Отчёт.Добавить("  " + ОписаниеОшибки());
		Отчёт.Добавить("");
		Отчёт.Добавить("Частые причины:");
		Отчёт.Добавить("  - firewall блокирует исходящие HTTP запросы на порт " + Строка(КОНСТ_Порт()));
		Отчёт.Добавить("  - DNS не резолвит " + КОНСТ_АдресСервиса());
		Отчёт.Добавить("  - 1С запущен с урезанными правами (безопасный режим)");
		ЗаписатьОшибкуВЖурнал("Ошибка GET /pending: " + ОписаниеОшибки());
		Возврат СоздатьОтчётСтроку(Отчёт);
	КонецПопытки;

	Отчёт.Добавить("HTTP ответ: код " + Строка(Ответ.КодСостояния));

	Если Ответ.КодСостояния = 401 Тогда
		Отчёт.Добавить("✗ 401 Unauthorized — неверный API-ключ.");
		Отчёт.Добавить("  Проверь константу КОНСТ_КлючAPI() в начале модуля объекта.");
		Отчёт.Добавить("  Сейчас: '" + КОНСТ_КлючAPI() + "'");
		Возврат СоздатьОтчётСтроку(Отчёт);
	КонецЕсли;

	Если Ответ.КодСостояния <> 200 Тогда
		Отчёт.Добавить("✗ API вернул код " + Строка(Ответ.КодСостояния));
		Попытка
			Отчёт.Добавить("  Тело: " + Лев(Ответ.ПолучитьТелоКакСтроку("UTF-8"), 500));
		Исключение
		КонецПопытки;
		Возврат СоздатьОтчётСтроку(Отчёт);
	КонецЕсли;

	ТелоОтвета = Ответ.ПолучитьТелоКакСтроку("UTF-8");

	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТелоОтвета);
		СтруктураОтвета = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		Отчёт.Добавить("✗ Не удалось разобрать JSON: " + ОписаниеОшибки());
		Отчёт.Добавить("  Тело ответа (первые 500 символов):");
		Отчёт.Добавить("  " + Лев(ТелоОтвета, 500));
		Возврат СоздатьОтчётСтроку(Отчёт);
	КонецПопытки;

	Если НЕ СтруктураОтвета.Свойство("data") Тогда
		Отчёт.Добавить("✗ В ответе нет поля 'data'");
		Возврат СоздатьОтчётСтроку(Отчёт);
	КонецЕсли;

	СписокНакладных = СтруктураОтвета.data;

	Отчёт.Добавить("Получено накладных с сервера: " + Строка(СписокНакладных.Количество()));

	Если СписокНакладных.Количество() = 0 Тогда
		Отчёт.Добавить("");
		Отчёт.Добавить("Нет накладных для загрузки.");
		Отчёт.Добавить("Чтобы накладная появилась здесь, открой её в дашборде");
		Отчёт.Добавить("scan.magday.ru и нажми кнопку 'Отправить в 1С'.");
		Возврат СоздатьОтчётСтроку(Отчёт);
	КонецЕсли;

	// =========================================================================
	// ШАГ 2: Для каждой накладной — создаём документ Приходная накладная
	// =========================================================================

	Отчёт.Добавить("");
	Отчёт.Добавить("--- Создание документов ---");

	КоличествоСоздано = 0;
	КоличествоОшибок = 0;

	Для Каждого ДанныеНакладной Из СписокНакладных Цикл

		Попытка
			СозданныйДокумент = СоздатьПриходнуюНакладную(ДанныеНакладной);

			Если СозданныйДокумент <> Неопределено И НЕ СозданныйДокумент.Пустая() Тогда
				// Скачать фото накладной и прикрепить к документу
				Попытка
					КолФото = ПрикрепитьФотоНакладной(ДанныеНакладной.id, СозданныйДокумент);
					Если КолФото > 0 Тогда
						Отчёт.Добавить("  Прикреплено фото: " + Строка(КолФото));
					КонецЕсли;
				Исключение
					Отчёт.Добавить("  Ошибка загрузки фото: " + ОписаниеОшибки());
				КонецПопытки;

				ПодтвердитьЗагрузку(ДанныеНакладной.id);
				КоличествоСоздано = КоличествоСоздано + 1;
				Отчёт.Добавить("✓ " + Строка(СозданныйДокумент));
			Иначе
				КоличествоОшибок = КоличествоОшибок + 1;
				Отчёт.Добавить("✗ id=" + Строка(ДанныеНакладной.id) + ": документ не создан");
			КонецЕсли;

		Исключение
			КоличествоОшибок = КоличествоОшибок + 1;
			ТекстОшибки = "id=" + Строка(ДанныеНакладной.id) + ": " + ОписаниеОшибки();
			Отчёт.Добавить("✗ " + ТекстОшибки);
			ЗаписатьОшибкуВЖурнал(ТекстОшибки);
		КонецПопытки;

	КонецЦикла;

	Отчёт.Добавить("");
	Отчёт.Добавить("=== Итого ===");
	Отчёт.Добавить("Создано документов: " + Строка(КоличествоСоздано));
	Отчёт.Добавить("Ошибок: " + Строка(КоличествоОшибок));

	// Auto-sync nomenclature back to the site after invoice load. When 1C
	// creates new catalog entries (first-time supplier items that the user
	// didn't map on the dashboard), those need to appear in the server-side
	// catalog so the user can then map scan names to them for future auto-
	// resolution. Otherwise the user has to manually click two buttons in a
	// row every time. Only runs if at least one document was created —
	// skipping the sync on empty/failed loads avoids pointless catalog churn.
	Если КоличествоСоздано > 0 Тогда
		Отчёт.Добавить("");
		Отчёт.Добавить("--- Автовыгрузка номенклатуры на сайт ---");
		Попытка
			ОтчётВыгрузки = ВыгрузитьНоменклатуруНаСайт();
			// Merge the nomenclature sync report into the main one so the user
			// sees everything in a single dialog.
			Для Каждого СтрокаОтчёта Из СтрРазделить(ОтчётВыгрузки, Символы.ПС, Ложь) Цикл
				Отчёт.Добавить(СтрокаОтчёта);
			КонецЦикла;
		Исключение
			Отчёт.Добавить("⚠ Автовыгрузка номенклатуры упала: " + ОписаниеОшибки());
			ЗаписатьОшибкуВЖурнал("Автовыгрузка номенклатуры после загрузки накладных: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;

	Возврат СоздатьОтчётСтроку(Отчёт);

КонецФункции

// Собирает массив строк в одну многострочную строку с переводами
// и также записывает полный отчёт в Журнал регистрации для отладки.
Функция СоздатьОтчётСтроку(Отчёт)

	Результат = "";
	Для Каждого Строка_ Из Отчёт Цикл
		Если НЕ ПустаяСтрока(Результат) Тогда
			Результат = Результат + Символы.ПС;
		КонецЕсли;
		Результат = Результат + Строка_;
	КонецЦикла;

	// Дублируем в Журнал регистрации
	Попытка
		СтруктураСобытий = Новый Структура("ИмяСобытия, ПредставлениеУровня, Комментарий, ДатаСобытия");
		СтруктураСобытий.ИмяСобытия = "Загрузка накладных со сканера";
		СтруктураСобытий.ПредставлениеУровня = "Информация";
		СтруктураСобытий.Комментарий = Результат;
		СтруктураСобытий.ДатаСобытия = ТекущаяДатаСеанса();

		СобытияДляЖурнала = Новый СписокЗначений();
		СобытияДляЖурнала.Добавить(СтруктураСобытий);
		ЖурналРегистрации.ЗаписатьСобытияВЖурналРегистрации(СобытияДляЖурнала);
	Исключение
	КонецПопытки;

	// Также выводим в окно сообщений (работает когда обработку открывают через Файл → Открыть)
	Попытка
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат);
	Исключение
	КонецПопытки;

	Возврат Результат;

КонецФункции

// ============================================================================
// СОЗДАНИЕ ДОКУМЕНТА "ПРИХОДНАЯ НАКЛАДНАЯ"
// ============================================================================

Функция СоздатьПриходнуюНакладную(ДанныеНакладной)

	// 2.1 Получаем полные данные накладной (включая товары) через отдельный GET
	//     — ответ /pending уже содержит items, но на всякий случай гарантируем
	ПолныеДанные = ДанныеНакладной;
	Если НЕ ПолныеДанные.Свойство("items") ИЛИ ТипЗнч(ПолныеДанные.items) <> Тип("Массив") Тогда
		ПолныеДанные = ПолучитьПолныеДанныеНакладной(ДанныеНакладной.id);
		Если ПолныеДанные = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;

	// 2.2 Определяем контрагента (по ИНН, если есть, иначе по имени)
	ИмяПоставщика = "";
	Если ПолныеДанные.Свойство("supplier") И ЗначениеЗаполнено(ПолныеДанные.supplier) Тогда
		ИмяПоставщика = ПолныеДанные.supplier;
	КонецЕсли;

	ИННПоставщика = "";
	Если ПолныеДанные.Свойство("supplier_inn") И ЗначениеЗаполнено(ПолныеДанные.supplier_inn) Тогда
		ИННПоставщика = ПолныеДанные.supplier_inn;
	КонецЕсли;

	Контрагент = НайтиИлиСоздатьКонтрагента(ИмяПоставщика, ИННПоставщика);
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		ВызватьИсключение "Не удалось определить контрагента (имя: " + ИмяПоставщика + ")";
	КонецЕсли;

	// 2.3 Парсим дату накладной
	ДатаВходящей = ТекущаяДата();
	Если ПолныеДанные.Свойство("invoice_date") И ЗначениеЗаполнено(ПолныеДанные.invoice_date) Тогда
		Попытка
			СтрДата = ПолныеДанные.invoice_date;
			ДатаВходящей = Дата(
				Число(Лев(СтрДата, 4)),
				Число(Сред(СтрДата, 6, 2)),
				Число(Сред(СтрДата, 9, 2))
			);
		Исключение
			ДатаВходящей = ТекущаяДата();
		КонецПопытки;
	КонецЕсли;

	// 2.4 Создаём документ
	НовыйДокумент = Документы.ПриходнаяНакладная.СоздатьДокумент();
	НовыйДокумент.Дата = ТекущаяДата();
	НовыйДокумент.ДатаВходящегоДокумента = ДатаВходящей;
	НовыйДокумент.Организация = Справочники.Организации.ОсновнаяОрганизация;
	НовыйДокумент.Контрагент = Контрагент;

	// Договор — "Основной договор"
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Попытка
			ЗапросДоговор = Новый Запрос;
			ЗапросДоговор.Текст =
				"ВЫБРАТЬ ПЕРВЫЕ 1 Договоры.Ссылка КАК Ссылка
				|ИЗ Справочник.ДоговорыКонтрагентов КАК Договоры
				|ГДЕ Договоры.Владелец = &Контрагент
				|    И Договоры.Наименование ПОДОБНО ""%Основной%""
				|    И НЕ Договоры.ПометкаУдаления";
			ЗапросДоговор.УстановитьПараметр("Контрагент", Контрагент);
			РезультатДоговор = ЗапросДоговор.Выполнить();
			Если НЕ РезультатДоговор.Пустой() Тогда
				ВыборкаДоговор = РезультатДоговор.Выбрать();
				ВыборкаДоговор.Следующий();
				// В УНФ реквизит может называться "Договор" или "ДоговорКонтрагента"
				Попытка
					НовыйДокумент.Договор = ВыборкаДоговор.Ссылка;
				Исключение
					Попытка
						НовыйДокумент.ДоговорКонтрагента = ВыборкаДоговор.Ссылка;
					Исключение
					КонецПопытки;
				КонецПопытки;
			КонецЕсли;
		Исключение
			// Реквизит может отсутствовать
		КонецПопытки;
	КонецЕсли;

	// Вид операции — "Поступление от поставщика" (документ попадает в журнал
	// "Документы по закупкам" подсистемы "Запасы и закупки → Закупки")
	Попытка
		НовыйДокумент.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика;
	Исключение
		// Перечисление может иметь другое имя в некоторых сборках
	КонецПопытки;

	// Налогообложение НДС — "Не облагается (без НДС)"
	Попытка
		НовыйДокумент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС;
	Исключение
		// Игнор
	КонецПопытки;

	// Валюта документа — рубль, курс = 1, кратность = 1
	Попытка
		Рубль = Справочники.Валюты.НайтиПоНаименованию("руб.", Истина);
		Если Рубль.Пустая() Тогда
			Рубль = Справочники.Валюты.НайтиПоНаименованию("Российский рубль", Истина);
		КонецЕсли;
		Если НЕ Рубль.Пустая() Тогда
			НовыйДокумент.ВалютаДокумента = Рубль;
		КонецЕсли;
		НовыйДокумент.Курс = 1;
		НовыйДокумент.Кратность = 1;
	Исключение
		// Игнор
	КонецПопытки;

	// Номер входящего документа
	Если ПолныеДанные.Свойство("invoice_number") И ЗначениеЗаполнено(ПолныеДанные.invoice_number) Тогда
		Попытка
			НовыйДокумент.НомерВходящегоДокумента = Строка(ПолныеДанные.invoice_number);
		Исключение
			// Игнор если реквизит отсутствует
		КонецПопытки;
	КонецЕсли;

	// Складская единица — берём первую доступную (обычно "Магазин" или "Основной склад")
	Попытка
		Склад = Справочники.СтруктурныеЕдиницы.НайтиПоНаименованию("Магазин", Истина);
		Если Склад.Пустая() Тогда
			Склад = Справочники.СтруктурныеЕдиницы.НайтиПоНаименованию("Основной склад", Истина);
		КонецЕсли;
		Если НЕ Склад.Пустая() Тогда
			НовыйДокумент.СтруктурнаяЕдиница = Склад;
		КонецЕсли;
	Исключение
		// Реквизит может называться иначе — игнорируем
	КонецПопытки;

	// Комментарий с ID накладной в сервисе (для отладки)
	Попытка
		НовыйДокумент.Комментарий = "#Загружено из scan.magday.ru, ID: " + Строка(ПолныеДанные.id);
	Исключение
		// Игнор
	КонецПопытки;

	// 2.5 Заполняем табличную часть "Запасы"
	Если НЕ ПолныеДанные.Свойство("items") ИЛИ ТипЗнч(ПолныеДанные.items) <> Тип("Массив") Тогда
		ВызватьИсключение "В накладной нет массива items";
	КонецЕсли;

	Для Каждого Товар Из ПолныеДанные.items Цикл

		// Приоритет: mapped_name (уже сопоставлено на сервере), потом original_name
		ИмяНоменклатуры = "";
		Если Товар.Свойство("mapped_name") И ЗначениеЗаполнено(Товар.mapped_name) Тогда
			ИмяНоменклатуры = Товар.mapped_name;
		ИначеЕсли Товар.Свойство("original_name") И ЗначениеЗаполнено(Товар.original_name) Тогда
			ИмяНоменклатуры = Товар.original_name;
		Иначе
			Продолжить;
		КонецЕсли;

		Номенклатура = Неопределено;

		// Fast path: onec_guid already set by dashboard — resolve directly via ПолучитьСсылку
		Если Товар.Свойство("onec_guid") И ЗначениеЗаполнено(Товар.onec_guid) Тогда
			Попытка
				УИД = Новый УникальныйИдентификатор(Товар.onec_guid);
				СсылкаКандидат = Справочники.Номенклатура.ПолучитьСсылку(УИД);
				Если ЗначениеЗаполнено(СсылкаКандидат) И НЕ СсылкаКандидат.ЭтоГруппа Тогда
					Номенклатура = СсылкаКандидат;
					ДозаполнитьНоменклатуру(Номенклатура);
				КонецЕсли;
			Исключение
				// Invalid GUID string — fall through to name lookup
			КонецПопытки;
		КонецЕсли;

		// Fallback: name-based lookup
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Номенклатура = НайтиИлиСоздатьНоменклатуру(ИмяНоменклатуры);
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				"  ⚠ Не удалось найти/создать номенклатуру: " + ИмяНоменклатуры);
			Продолжить;
		КонецЕсли;

		НоваяСтрока = НовыйДокумент.Запасы.Добавить();
		НоваяСтрока.Номенклатура = Номенклатура;

		// Количество
		Если Товар.Свойство("quantity") И ЗначениеЗаполнено(Товар.quantity) Тогда
			НоваяСтрока.Количество = Товар.quantity;
		Иначе
			НоваяСтрока.Количество = 1;
		КонецЕсли;

		// Цена
		Если Товар.Свойство("price") И ЗначениеЗаполнено(Товар.price) Тогда
			НоваяСтрока.Цена = Товар.price;
		КонецЕсли;

		// Сумма
		Если Товар.Свойство("total") И ЗначениеЗаполнено(Товар.total) Тогда
			НоваяСтрока.Сумма = Товар.total;
		Иначе
			НоваяСтрока.Сумма = НоваяСтрока.Количество * НоваяСтрока.Цена;
		КонецЕсли;

		// СуммаНДС = 0 (без НДС)
		Попытка
			НоваяСтрока.СуммаНДС = 0;
		Исключение
		КонецПопытки;

		// Всего (с НДС) = Сумма (т.к. без НДС)
		Попытка
			НоваяСтрока.Всего = НоваяСтрока.Сумма;
		Исключение
			// Реквизит может отсутствовать
		КонецПопытки;

		// Единица измерения
		Попытка
			Если Товар.Свойство("unit") И ЗначениеЗаполнено(Товар.unit) Тогда
				ЕдИзм = НайтиЕдиницуИзмерения(Товар.unit);
				Если ЗначениеЗаполнено(ЕдИзм) Тогда
					НоваяСтрока.ЕдиницаИзмерения = ЕдИзм;
				КонецЕсли;
			Иначе
				НоваяСтрока.ЕдиницаИзмерения = Номенклатура.ЕдиницаИзмерения;
			КонецЕсли;
		Исключение
			// Игнор
		КонецПопытки;

		// Ставка НДС — ищем "Без НДС" в справочнике СтавкиНДС
		Попытка
			СтавкаБезНДС = Справочники.СтавкиНДС.НайтиПоНаименованию("Без НДС", Истина);
			Если ЗначениеЗаполнено(СтавкаБезНДС) Тогда
				НоваяСтрока.СтавкаНДС = СтавкаБезНДС;
			КонецЕсли;
		Исключение
			// Игнор
		КонецПопытки;

	КонецЦикла;

	// 2.6 Сумма документа (берём из API или пересчитываем)
	Попытка
		Если ПолныеДанные.Свойство("total_sum") И ЗначениеЗаполнено(ПолныеДанные.total_sum) Тогда
			НовыйДокумент.СуммаДокумента = ПолныеДанные.total_sum;
		КонецЕсли;
	Исключение
		// Игнор
	КонецПопытки;

	// 2.7 Запись документа БЕЗ проведения (пользователь проверит и проведёт вручную)
	Попытка
		НовыйДокумент.Записать();
		Возврат НовыйДокумент.Ссылка;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ВызватьИсключение "Ошибка записи документа: " + ТекстОшибки;
	КонецПопытки;

КонецФункции

// ============================================================================
// ПОИСК / СОЗДАНИЕ КОНТРАГЕНТА
// ============================================================================

Процедура ДозаполнитьСчётКонтрагента(Контрагент)
	Попытка
		Если НЕ ЗначениеЗаполнено(Контрагент.СчетУчетаРасчетовСПоставщиком) Тогда
			КонтрОбъект = Контрагент.ПолучитьОбъект();
			КонтрОбъект.СчетУчетаРасчетовСПоставщиком = ПланыСчетов.Управленческий.РасчетыСПоставщиками;
			КонтрОбъект.Записать();
		КонецЕсли;
	Исключение
	КонецПопытки;
КонецПроцедуры

Функция НайтиИлиСоздатьКонтрагента(ИмяКонтрагента, ИНН = "")

	Если ПустаяСтрока(ИмяКонтрагента) И ПустаяСтрока(ИНН) Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;

	// 1. Если есть ИНН — ищем по нему (самый надёжный способ)
	Если НЕ ПустаяСтрока(ИНН) Тогда
		Попытка
			Запрос = Новый Запрос;
			Запрос.Текст =
				"ВЫБРАТЬ ПЕРВЫЕ 1
				|	Контрагенты.Ссылка КАК Ссылка
				|ИЗ
				|	Справочник.Контрагенты КАК Контрагенты
				|ГДЕ
				|	Контрагенты.ИНН = &ИНН
				|	И НЕ Контрагенты.ПометкаУдаления";
			Запрос.УстановитьПараметр("ИНН", ИНН);

			Результат = Запрос.Выполнить();
			Если НЕ Результат.Пустой() Тогда
				Выборка = Результат.Выбрать();
				Выборка.Следующий();
				ДозаполнитьСчётКонтрагента(Выборка.Ссылка);
				Возврат Выборка.Ссылка;
			КонецЕсли;
		Исключение
			// Реквизит ИНН может отсутствовать в этой конфигурации — продолжаем по имени
		КонецПопытки;
	КонецЕсли;

	// 2. Поиск по точному наименованию
	Если НЕ ПустаяСтрока(ИмяКонтрагента) Тогда
		Контрагент = Справочники.Контрагенты.НайтиПоНаименованию(ИмяКонтрагента, Истина);
		Если ЗначениеЗаполнено(Контрагент) Тогда
			ДозаполнитьСчётКонтрагента(Контрагент);
			Возврат Контрагент;
		КонецЕсли;
	КонецЕсли;

	// 3. Нечёткий поиск (после очистки имени от юр. формы и кавычек)
	Если НЕ ПустаяСтрока(ИмяКонтрагента) Тогда
		ОчищенноеИмя = ОчиститьНаименованиеКонтрагента(ИмяКонтрагента);
		Если НЕ ПустаяСтрока(ОчищенноеИмя) Тогда
			Запрос = Новый Запрос;
			Запрос.Текст =
				"ВЫБРАТЬ ПЕРВЫЕ 1
				|	Контрагенты.Ссылка КАК Ссылка
				|ИЗ
				|	Справочник.Контрагенты КАК Контрагенты
				|ГДЕ
				|	Контрагенты.Наименование ПОДОБНО &Имя
				|	И НЕ Контрагенты.ПометкаУдаления";
			Запрос.УстановитьПараметр("Имя", "%" + ОчищенноеИмя + "%");

			Результат = Запрос.Выполнить();
			Если НЕ Результат.Пустой() Тогда
				Выборка = Результат.Выбрать();
				Выборка.Следующий();
				ДозаполнитьСчётКонтрагента(Выборка.Ссылка);
				Возврат Выборка.Ссылка;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	// 4. Не нашли — создаём нового
	НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
	НовыйКонтрагент.Наименование = ИмяКонтрагента;

	Если НЕ ПустаяСтрока(ИНН) Тогда
		Попытка
			НовыйКонтрагент.ИНН = ИНН;
		Исключение
			// Реквизит может отсутствовать
		КонецПопытки;
	КонецЕсли;

	// Тип: физическое (ИП) или юридическое
	Попытка
		Если СтрНачинаетсяС(ВРег(ИмяКонтрагента), "ИП ") Тогда
			НовыйКонтрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
		Иначе
			НовыйКонтрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
		КонецЕсли;
	Исключение
		// Игнор
	КонецПопытки;

	// Отмечаем как поставщика
	Попытка
		НовыйКонтрагент.Поставщик = Истина;
	Исключение
		// Игнор
	КонецПопытки;

	// Счёт расчётов с поставщиком
	Попытка
		НовыйКонтрагент.СчетУчетаРасчетовСПоставщиком = ПланыСчетов.Управленческий.РасчетыСПоставщиками;
	Исключение
	КонецПопытки;

	Попытка
		НовыйКонтрагент.Записать();
		Возврат НовыйКонтрагент.Ссылка;
	Исключение
		ЗаписатьОшибкуВЖурнал("Ошибка создания контрагента '" + ИмяКонтрагента + "': " + ОписаниеОшибки());
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецПопытки;

КонецФункции

Функция ОчиститьНаименованиеКонтрагента(Имя)

	Результат = Имя;

	Результат = СтрЗаменить(Результат, """", "");
	Результат = СтрЗаменить(Результат, "«", "");
	Результат = СтрЗаменить(Результат, "»", "");

	Результат = ВРег(Результат);
	Результат = СтрЗаменить(Результат, "ООО ", "");
	Результат = СтрЗаменить(Результат, "ОАО ", "");
	Результат = СтрЗаменить(Результат, "ЗАО ", "");
	Результат = СтрЗаменить(Результат, "ПАО ", "");
	Результат = СтрЗаменить(Результат, "АО ", "");
	Результат = СтрЗаменить(Результат, "ИП ", "");

	Возврат СокрЛП(Результат);

КонецФункции

// ============================================================================
// ДОЗАПОЛНЕНИЕ СУЩЕСТВУЮЩЕЙ НОМЕНКЛАТУРЫ
// ============================================================================

Процедура ДозаполнитьНоменклатуру(Номенклатура)
	Попытка
		// Проверяем, нужно ли что-то дозаполнить
		НужноЗаписать = Ложь;
		НужноСчета = НЕ ЗначениеЗаполнено(Номенклатура.СчетУчетаЗапасов);
		НужноКатегорию = Ложь;
		НужноНаимПечати = Ложь;
		НужноАртикул = Ложь;

		Попытка
			НужноКатегорию = НЕ ЗначениеЗаполнено(Номенклатура.КатегорияНоменклатуры);
		Исключение
		КонецПопытки;
		Попытка
			НужноНаимПечати = НЕ ЗначениеЗаполнено(Номенклатура.НаименованиеПолное);
		Исключение
		КонецПопытки;
		Попытка
			НужноАртикул = НЕ ЗначениеЗаполнено(Номенклатура.Артикул);
		Исключение
		КонецПопытки;

		Если НЕ НужноСчета И НЕ НужноКатегорию И НЕ НужноНаимПечати И НЕ НужноАртикул Тогда
			Возврат;
		КонецЕсли;

		НомОбъект = Номенклатура.ПолучитьОбъект();

		// Счета учёта
		Если НужноСчета Тогда
			Попытка НомОбъект.СчетУчетаЗапасов = ПланыСчетов.Управленческий.ТоварыПродукция; Исключение КонецПопытки;
			Попытка НомОбъект.СчетУчетаДоходов = ПланыСчетов.Управленческий.ДоходыРасходы; Исключение КонецПопытки;
			Попытка НомОбъект.СчетУчетаЗатрат = ПланыСчетов.Управленческий.СебестоимостьПродаж; Исключение КонецПопытки;
			НужноЗаписать = Истина;
		КонецЕсли;

		// Категория
		Если НужноКатегорию Тогда
			Попытка
				Категория = Справочники.КатегорииНоменклатуры.НайтиПоНаименованию("Продукты", Истина);
				Если ЗначениеЗаполнено(Категория) Тогда
					НомОбъект.КатегорияНоменклатуры = Категория;
					НужноЗаписать = Истина;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЕсли;

		// Наименование для печати
		Если НужноНаимПечати Тогда
			Попытка
				НомОбъект.НаименованиеПолное = НомОбъект.Наименование;
				НужноЗаписать = Истина;
			Исключение
			КонецПопытки;
		КонецЕсли;

		// Артикул
		Если НужноАртикул Тогда
			Попытка
				НомОбъект.Артикул = Формат(ТекущаяДата(), "ДФ=yyMMddHHmmss");
				НужноЗаписать = Истина;
			Исключение
			КонецПопытки;
		КонецЕсли;

		Если НужноЗаписать Тогда
			НомОбъект.Записать();
		КонецЕсли;
	Исключение
		// Нет прав или другая ошибка — не критично
	КонецПопытки;
КонецПроцедуры

// ============================================================================
// ПОИСК / СОЗДАНИЕ НОМЕНКЛАТУРЫ
// ============================================================================

Функция НайтиИлиСоздатьНоменклатуру(ИмяНоменклатуры)

	Если ПустаяСтрока(ИмяНоменклатуры) Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;

	// 1. Поиск по точному наименованию
	Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(ИмяНоменклатуры, Истина);
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		ДозаполнитьНоменклатуру(Номенклатура);
		Возврат Номенклатура;
	КонецЕсли;

	// 2. Создаём новую
	НоваяНоменклатура = Справочники.Номенклатура.СоздатьЭлемент();
	НоваяНоменклатура.Наименование = Лев(ИмяНоменклатуры, 150);

	// Наименование для печати
	Попытка
		НоваяНоменклатура.НаименованиеПолное = Лев(ИмяНоменклатуры, 150);
	Исключение
	КонецПопытки;

	Попытка
		НоваяНоменклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас;
	Исключение
		Попытка
			НоваяНоменклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Товар;
		Исключение
		КонецПопытки;
	КонецПопытки;

	// Категория — "Продукты"
	Попытка
		Категория = Справочники.КатегорииНоменклатуры.НайтиПоНаименованию("Продукты", Истина);
		Если ЗначениеЗаполнено(Категория) Тогда
			НоваяНоменклатура.КатегорияНоменклатуры = Категория;
		КонецЕсли;
	Исключение
	КонецПопытки;

	// Артикул — генерируем из текущего времени (уникальный)
	Попытка
		НоваяНоменклатура.Артикул = Формат(ТекущаяДата(), "ДФ=yyMMddHHmmss");
	Исключение
	КонецПопытки;

	// Базовая единица — кг (основная для продуктов)
	Попытка
		ЕдИзм = Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию("кг", Истина);
		Если НЕ ЗначениеЗаполнено(ЕдИзм) Тогда
			ЕдИзм = Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию("шт", Истина);
		КонецЕсли;
		Если ЗначениеЗаполнено(ЕдИзм) Тогда
			НоваяНоменклатура.ЕдиницаИзмерения = ЕдИзм;
		КонецЕсли;
	Исключение
	КонецПопытки;

	// Счёт учёта запасов — "Товары, продукция" (код 41)
	Попытка
		НоваяНоменклатура.СчетУчетаЗапасов = ПланыСчетов.Управленческий.ТоварыПродукция;
	Исключение
	КонецПопытки;

	// Счёт учёта доходов — "Доходы-расходы" (если есть)
	Попытка
		НоваяНоменклатура.СчетУчетаДоходов = ПланыСчетов.Управленческий.ДоходыРасходы;
	Исключение
	КонецПопытки;

	// Счёт учёта затрат
	Попытка
		НоваяНоменклатура.СчетУчетаЗатрат = ПланыСчетов.Управленческий.СебестоимостьПродаж;
	Исключение
	КонецПопытки;

	Попытка
		НоваяНоменклатура.Записать();
		Возврат НоваяНоменклатура.Ссылка;
	Исключение
		ЗаписатьОшибкуВЖурнал("Ошибка создания номенклатуры '" + ИмяНоменклатуры + "': " + ОписаниеОшибки());
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецПопытки;

КонецФункции

Функция НайтиЕдиницуИзмерения(КодЕдиницы)

	СоответствиеЕдиниц = Новый Соответствие;
	СоответствиеЕдиниц.Вставить("шт", "шт");
	СоответствиеЕдиниц.Вставить("кг", "кг");
	СоответствиеЕдиниц.Вставить("л", "л");
	СоответствиеЕдиниц.Вставить("уп", "уп");
	СоответствиеЕдиниц.Вставить("упак", "уп");
	СоответствиеЕдиниц.Вставить("пач", "пач");
	СоответствиеЕдиниц.Вставить("бут", "бут");

	ИмяЕдиницы = СоответствиеЕдиниц.Получить(НРег(КодЕдиницы));
	Если ИмяЕдиницы = Неопределено Тогда
		ИмяЕдиницы = КодЕдиницы;
	КонецЕсли;

	Попытка
		Возврат Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию(ИмяЕдиницы, Истина);
	Исключение
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

// ============================================================================
// ВЗАИМОДЕЙСТВИЕ С API
// ============================================================================

Функция СоздатьHTTPСоединение()

	Попытка
		Если КОНСТ_ИспользоватьSSL() Тогда
			Соединение = Новый HTTPСоединение(
				КОНСТ_АдресСервиса(),
				КОНСТ_Порт(),
				, , , ,
				Новый ЗащищенноеСоединениеOpenSSL()
			);
		Иначе
			Соединение = Новый HTTPСоединение(
				КОНСТ_АдресСервиса(),
				КОНСТ_Порт()
			);
		КонецЕсли;
		Возврат Соединение;
	Исключение
		ЗаписатьОшибкуВЖурнал("Не удалось установить соединение с " + КОНСТ_АдресСервиса() + ": " + ОписаниеОшибки());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось подключиться к " + КОНСТ_АдресСервиса());
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

// Скачать фото накладной с сервиса и прикрепить к документу
//
Функция ПрикрепитьФотоНакладной(ИдНакладной, СсылкаДокумента)

	Соединение = СоздатьHTTPСоединение();
	Если Соединение = Неопределено Тогда
		Возврат 0;
	КонецЕсли;

	// 1. Получить список фото
	Запрос = Новый HTTPЗапрос("/api/invoices/" + Формат(ИдНакладной, "ЧГ=0") + "/photos");
	Запрос.Заголовки.Вставить("X-API-Key", КОНСТ_КлючAPI());

	Попытка
		Ответ = Соединение.Получить(Запрос);
	Исключение
		Возврат 0;
	КонецПопытки;

	Если Ответ.КодСостояния <> 200 Тогда
		Возврат 0;
	КонецЕсли;

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку("UTF-8"));
	Результат = ПрочитатьJSON(ЧтениеJSON);

	СписокФото = Неопределено;
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("data") Тогда
		СписокФото = Результат.data;
	ИначеЕсли ТипЗнч(Результат) = Тип("Массив") Тогда
		СписокФото = Результат;
	КонецЕсли;

	Если СписокФото = Неопределено ИЛИ СписокФото.Количество() = 0 Тогда
		Возврат 0;
	КонецЕсли;

	КоличествоПрикреплено = 0;

	// 2. Скачать каждое фото и прикрепить
	Для Каждого Фото Из СписокФото Цикл

		URL = "";
		ИмяФайла = "";
		Если ТипЗнч(Фото) = Тип("Структура") Тогда
			Если Фото.Свойство("url") Тогда URL = Фото.url; КонецЕсли;
			Если Фото.Свойство("filename") Тогда ИмяФайла = Фото.filename; КонецЕсли;
		КонецЕсли;

		Если ПустаяСтрока(URL) Тогда Продолжить; КонецЕсли;

		// Скачать бинарные данные фото
		ЗапросФото = Новый HTTPЗапрос(URL);
		ЗапросФото.Заголовки.Вставить("X-API-Key", КОНСТ_КлючAPI());

		Попытка
			ОтветФото = Соединение.Получить(ЗапросФото);
		Исключение
			Продолжить;
		КонецПопытки;

		Если ОтветФото.КодСостояния <> 200 Тогда Продолжить; КонецЕсли;

		ДвоичныеДанные = ОтветФото.ПолучитьТелоКакДвоичныеДанные();
		Если ДвоичныеДанные = Неопределено Тогда Продолжить; КонецЕсли;

		// Определить расширение
		Расширение = "jpg";
		ПозТочки = СтрНайти(ИмяФайла, ".", НаправлениеПоиска.СКонца);
		Если ПозТочки > 0 Тогда
			Расширение = НРег(Сред(ИмяФайла, ПозТочки + 1));
		КонецЕсли;

		// Имя без расширения
		ИмяБезРасширения = ИмяФайла;
		Если ПозТочки > 0 Тогда
			ИмяБезРасширения = Лев(ИмяФайла, ПозТочки - 1);
		КонецЕсли;

		// Создать присоединённый файл
		Попытка
			НовыйФайл = Справочники.ПриходнаяНакладнаяПрисоединенныеФайлы.СоздатьЭлемент();
			НовыйФайл.Наименование = ИмяБезРасширения;
			НовыйФайл.ВладелецФайла = СсылкаДокумента;
			НовыйФайл.Расширение = Расширение;
			НовыйФайл.Размер = ДвоичныеДанные.Размер();
			НовыйФайл.ДатаСоздания = ТекущаяДата();
			НовыйФайл.ДатаМодификацииУниверсальная = ТекущаяДата();

			// Сохранить двоичные данные в хранилище файла
			НовыйФайл.ТипХраненияФайла = Перечисления.ТипыХраненияФайлов.ВИнформационнойБазе;
			НовыйФайл.ФайлХранилище = Новый ХранилищеЗначения(ДвоичныеДанные);

			НовыйФайл.Записать();
			КоличествоПрикреплено = КоличествоПрикреплено + 1;
		Исключение
			ЗаписатьОшибкуВЖурнал("Ошибка прикрепления фото '" + ИмяФайла + "': " + ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	Возврат КоличествоПрикреплено;

КонецФункции

Функция ПолучитьПолныеДанныеНакладной(ИдНакладной)

	Соединение = СоздатьHTTPСоединение();
	Если Соединение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос = Новый HTTPЗапрос("/api/invoices/" + Формат(ИдНакладной, "ЧГ=0"));
	Запрос.Заголовки.Вставить("X-API-Key", КОНСТ_КлючAPI());

	Попытка
		Ответ = Соединение.Получить(Запрос);
	Исключение
		ЗаписатьОшибкуВЖурнал("GET /api/invoices/" + ИдНакладной + " упал: " + ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;

	Если Ответ.КодСостояния <> 200 Тогда
		Возврат Неопределено;
	КонецЕсли;

	ТелоОтвета = Ответ.ПолучитьТелоКакСтроку("UTF-8");
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТелоОтвета);
	Данные = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();

	Если ТипЗнч(Данные) = Тип("Структура") И Данные.Свойство("data") Тогда
		Возврат Данные.data;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Процедура ПодтвердитьЗагрузку(ИдНакладной)

	Соединение = СоздатьHTTPСоединение();
	Если Соединение = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый HTTPЗапрос("/api/invoices/" + Формат(ИдНакладной, "ЧГ=0") + "/confirm");
	Запрос.Заголовки.Вставить("X-API-Key", КОНСТ_КлючAPI());
	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	Запрос.УстановитьТелоИзСтроки("{}", "UTF-8");

	Попытка
		Ответ = Соединение.ОтправитьДляОбработки(Запрос);
		Если Ответ.КодСостояния <> 200 Тогда
			ЗаписатьОшибкуВЖурнал("Confirm вернул код " + Строка(Ответ.КодСостояния) + " для id=" + ИдНакладной);
		КонецЕсли;
	Исключение
		ЗаписатьОшибкуВЖурнал("Ошибка confirm id=" + ИдНакладной + ": " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// ============================================================================
// ЛОГИРОВАНИЕ
// ============================================================================

Процедура ЗаписатьОшибкуВЖурнал(Текст)

	СтруктураСобытий = Новый Структура("ИмяСобытия, ПредставлениеУровня, Комментарий, ДатаСобытия");
	СтруктураСобытий.ИмяСобытия = "Загрузка накладных со сканера";
	СтруктураСобытий.ПредставлениеУровня = "Ошибка";
	СтруктураСобытий.Комментарий = Текст;
	СтруктураСобытий.ДатаСобытия = ТекущаяДатаСеанса();

	СобытияДляЖурнала = Новый СписокЗначений();
	СобытияДляЖурнала.Добавить(СтруктураСобытий);

	Попытка
		ЖурналРегистрации.ЗаписатьСобытияВЖурналРегистрации(СобытияДляЖурнала);
	Исключение
		// Если журнал недоступен — хотя бы выводим в окно сообщений
	КонецПопытки;

КонецПроцедуры

// ============================================================================
// ВЫГРУЗКА СПРАВОЧНИКА НОМЕНКЛАТУРЫ НА САЙТ
// ============================================================================

Функция ВыгрузитьНоменклатуруНаСайт() Экспорт

	Отчёт = Новый Массив;
	Отчёт.Добавить("=== Выгрузка номенклатуры на сайт ===");
	Отчёт.Добавить("Сервер: " + КОНСТ_АдресСервиса() + ":" + Строка(КОНСТ_Порт()));
	Отчёт.Добавить("");

	// Catch-all guard: any unhandled exception (query error, JSON serialization
	// failure, missing optional fields like Весовой in some УНФ builds) must not
	// bubble up to the Additional Processing framework, which surfaces them as
	// the opaque "Значение содержит данные недопустимых типов" modal. Keep all
	// failure modes visible inside the report string instead.
	Попытка

		// Step 0: clear the server catalog before re-syncing. We switched the
		// source query from "all Справочник.Номенклатура" to "items that appear
		// in recent purchase documents", so stale rows (finished products,
		// semi-finished goods) from the old approach must be evicted — otherwise
		// they keep showing up as autocomplete suggestions on the site and get
		// wrongly matched to raw ingredients in scanned invoices.
		РезультатОчистки = ОчиститьКаталогНаСервере();
		Если НЕ РезультатОчистки.Успех Тогда
			Отчёт.Добавить("✗ Не удалось очистить каталог: " + РезультатОчистки.Ошибка);
			Возврат СоздатьОтчётСтроку(Отчёт);
		КонецЕсли;
		Отчёт.Добавить("Каталог на сервере очищен (удалено: " + Строка(РезультатОчистки.Удалено) + ")");

		// Purchase-documents-driven sync: take the LAST 10 posted Приходные
		// накладные (by date desc), collect DISTINCT nomenclature from their
		// Запасы tables. Date-based windows were fragile (the user's most recent
		// invoice turned out to be 7 months old) so we switched to a top-N
		// approach — always pulls something relevant regardless of posting gaps.
		// ПЕРВЫЕ N in 1C query language must be a compile-time literal, not a
		// parameter — if you need to change the count, edit the query text below.
		КоличествоДокументов = 10;

		Запрос = Новый Запрос;
		// Two-stage query: the inner subquery collects the SET of nomenclature
		// refs that appear in the last 10 posted Приходные накладные, and the
		// outer query selects all fields from Справочник.Номенклатура for that
		// set. We CANNOT put DISTINCT on the outer query because НаименованиеПолное
		// is a string of unlimited length (type Строка, неогр.) — 1C query
		// language rejects DISTINCT/UNION over such columns. Filtering via
		// "Номенклатура.Ссылка В (...)" naturally de-duplicates without DISTINCT.
		//
		// ЕСТЬNULL on every potentially-null text column — ЗаписатьJSON does NOT
		// accept SQL Null, only Неопределено, so coerce to empty string here.
		// NB: the inner subquery does NOT filter by Проведен. By design, the
		// "Загрузить накладные со сканера" command writes documents WITHOUT
		// posting them (пользователь проверяет и проводит вручную). Excluding
		// unposted docs would mean that new nomenclature created during that
		// load wouldn't flow back to the site until the user manually posts,
		// breaking the learning loop. The ПометкаУдаления check on Номенклатура
		// prevents trash, and the top-10 window naturally bounds the set.
		Запрос.Текст =
			"ВЫБРАТЬ
			|	Номенклатура.Ссылка КАК Ссылка,
			|	ЕСТЬNULL(Номенклатура.Код, """") КАК Код,
			|	ЕСТЬNULL(Номенклатура.Наименование, """") КАК Наименование,
			|	ЕСТЬNULL(Номенклатура.НаименованиеПолное, """") КАК НаименованиеПолное,
			|	ЕСТЬNULL(Номенклатура.ЕдиницаИзмерения.Наименование, """") КАК ЕдиницаИзмерения,
			|	Номенклатура.Родитель КАК Родитель,
			|	Номенклатура.ЭтоГруппа КАК ЭтоГруппа
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	Номенклатура.Ссылка В
			|		(ВЫБРАТЬ
			|			Запасы.Номенклатура
			|		ИЗ
			|			Документ.ПриходнаяНакладная.Запасы КАК Запасы
			|		ГДЕ
			|			Запасы.Ссылка В
			|				(ВЫБРАТЬ ПЕРВЫЕ 10
			|					Док.Ссылка
			|				ИЗ
			|					Документ.ПриходнаяНакладная КАК Док
			|				ГДЕ
			|					НЕ Док.ПометкаУдаления
			|				УПОРЯДОЧИТЬ ПО
			|					Док.Дата УБЫВ))
			|	И НЕ Номенклатура.ПометкаУдаления";

		Выборка = Запрос.Выполнить().Выбрать();

		Отчёт.Добавить("Источник: последние " + Строка(КоличествоДокументов) + " проведённых Приходных накладных");

		РазмерБатча = 500;
		Батч = Новый Массив;
		ВсегоВыгружено = 0;
		ВсегоПапок = 0;
		ВсегоТоваров = 0;

		Пока Выборка.Следующий() Цикл

			Запись = Новый Структура;
			Запись.Вставить("guid", Строка(Выборка.Ссылка.УникальныйИдентификатор()));
			Запись.Вставить("code", СокрЛП(Строка(Выборка.Код)));
			Запись.Вставить("name", Строка(Выборка.Наименование));
			Запись.Вставить("full_name", Строка(Выборка.НаименованиеПолное));
			Запись.Вставить("unit", Строка(Выборка.ЕдиницаИзмерения));
			Запись.Вставить("is_folder", Выборка.ЭтоГруппа = Истина);
			// is_weighted: Весовой reqval may not exist in all УНФ builds.
			// Попытка-safe read via the object so the whole query survives.
			ВесовойЗначение = Ложь;
			Попытка
				Объект = Выборка.Ссылка.ПолучитьОбъект();
				Если Объект <> Неопределено Тогда
					ВесовойЗначение = Объект.Весовой = Истина;
				КонецЕсли;
			Исключение
				// Реквизит Весовой может отсутствовать
			КонецПопытки;
			Запись.Вставить("is_weighted", ВесовойЗначение);

			Если ЗначениеЗаполнено(Выборка.Родитель) Тогда
				Запись.Вставить("parent_guid", Строка(Выборка.Родитель.УникальныйИдентификатор()));
			Иначе
				// Use empty string rather than Неопределено — safer across JSON writer versions.
				Запись.Вставить("parent_guid", "");
			КонецЕсли;

			Батч.Добавить(Запись);

			Если Выборка.ЭтоГруппа Тогда
				ВсегоПапок = ВсегоПапок + 1;
			Иначе
				ВсегоТоваров = ВсегоТоваров + 1;
			КонецЕсли;

			Если Батч.Количество() >= РазмерБатча Тогда
				Результат = ОтправитьБатчНоменклатуры(Батч);
				Если НЕ Результат.Успех Тогда
					Отчёт.Добавить("✗ Ошибка отправки батча: " + Результат.Ошибка);
					Возврат СоздатьОтчётСтроку(Отчёт);
				КонецЕсли;
				ВсегоВыгружено = ВсегоВыгружено + Результат.Выгружено;
				Батч.Очистить();
			КонецЕсли;

		КонецЦикла;

		// Последний батч
		Если Батч.Количество() > 0 Тогда
			Результат = ОтправитьБатчНоменклатуры(Батч);
			Если НЕ Результат.Успех Тогда
				Отчёт.Добавить("✗ Ошибка отправки последнего батча: " + Результат.Ошибка);
				Возврат СоздатьОтчётСтроку(Отчёт);
			КонецЕсли;
			ВсегоВыгружено = ВсегоВыгружено + Результат.Выгружено;
		КонецЕсли;

		Отчёт.Добавить("Выгружено позиций: " + Строка(ВсегоВыгружено));
		Отчёт.Добавить("  Папок:   " + Строка(ВсегоПапок));
		Отчёт.Добавить("  Товаров: " + Строка(ВсегоТоваров));

	Исключение
		ТекстИсключения = ОписаниеОшибки();
		Отчёт.Добавить("✗ Внутренняя ошибка:");
		Отчёт.Добавить("  " + ТекстИсключения);
		ЗаписатьОшибкуВЖурнал("ВыгрузитьНоменклатуруНаСайт упала: " + ТекстИсключения);
	КонецПопытки;

	Возврат СоздатьОтчётСтроку(Отчёт);

КонецФункции

// Clears the remote nomenclature catalog before re-sync. Called once at the
// start of ВыгрузитьНоменклатуруНаСайт so that the new purchase-documents-only
// query rebuilds the catalog from scratch instead of leaving stale finished
// products from the old "all catalog" sync behind.
Функция ОчиститьКаталогНаСервере()

	Соединение = СоздатьHTTPСоединение();
	Если Соединение = Неопределено Тогда
		Возврат Новый Структура("Успех, Ошибка, Удалено", Ложь, "Нет соединения", 0);
	КонецЕсли;

	Запрос = Новый HTTPЗапрос("/api/nomenclature");
	Запрос.Заголовки.Вставить("X-API-Key", КОНСТ_КлючAPI());

	Попытка
		Ответ = Соединение.Удалить(Запрос);
	Исключение
		Возврат Новый Структура("Успех, Ошибка, Удалено", Ложь, ОписаниеОшибки(), 0);
	КонецПопытки;

	Если Ответ.КодСостояния <> 200 Тогда
		Возврат Новый Структура("Успех, Ошибка, Удалено", Ложь,
			"HTTP " + Строка(Ответ.КодСостояния), 0);
	КонецЕсли;

	Возврат Новый Структура("Успех, Ошибка, Удалено", Истина, "", 0);

КонецФункции

Функция ОтправитьБатчНоменклатуры(Батч)

	Соединение = СоздатьHTTPСоединение();
	Если Соединение = Неопределено Тогда
		Возврат Новый Структура("Успех, Ошибка, Выгружено", Ложь, "Нет соединения", 0);
	КонецЕсли;

	Тело = Новый Структура;
	Тело.Вставить("items", Батч);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Тело);
	СтрокаТела = ЗаписьJSON.Закрыть();

	Запрос = Новый HTTPЗапрос("/api/nomenclature/sync");
	Запрос.Заголовки.Вставить("X-API-Key", КОНСТ_КлючAPI());
	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	Запрос.УстановитьТелоИзСтроки(СтрокаТела, "UTF-8");

	Попытка
		Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	Исключение
		Возврат Новый Структура("Успех, Ошибка, Выгружено", Ложь, ОписаниеОшибки(), 0);
	КонецПопытки;

	Если Ответ.КодСостояния <> 200 Тогда
		Возврат Новый Структура("Успех, Ошибка, Выгружено", Ложь,
			"HTTP " + Строка(Ответ.КодСостояния), 0);
	КонецЕсли;

	Возврат Новый Структура("Успех, Ошибка, Выгружено", Истина, "", Батч.Количество());

КонецФункции
