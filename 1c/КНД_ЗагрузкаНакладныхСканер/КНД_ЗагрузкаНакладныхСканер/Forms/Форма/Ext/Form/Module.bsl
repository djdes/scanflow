
&НаСервере
Функция ЗагрузитьНакладныеНаСервере()
	ОбъектОбработка = РеквизитФормыВЗначение("Объект");
	Возврат ОбъектОбработка.ЗагрузитьНакладныеСоСканера();
КонецФункции

&НаКлиенте
Процедура ЗагрузитьНакладные(Команда)
	Отчёт = ЗагрузитьНакладныеНаСервере();
	ПоказатьПредупреждение(, Отчёт, 30);
КонецПроцедуры

&НаСервере
Функция ВыгрузитьНоменклатуруНаСервере(ВыбранныеКатегории)
	// Сохраняем выбор пользователя для следующего раза
	ХранилищеОбщихНастроек.Сохранить("КНД_ЗагрузкаНакладныхСканер", "ВыбранныеКатегории", ВыбранныеКатегории);

	ОбъектОбработка = РеквизитФормыВЗначение("Объект");
	Возврат ОбъектОбработка.ВыгрузитьНоменклатуруНаСайт(ВыбранныеКатегории);
КонецФункции

&НаСервере
Процедура ЗаполнитьКатегорииНаСервере()
	// Получаем все категории из справочника
	Запрос = Новый Запрос("ВЫБРАТЬ Наименование ИЗ Справочник.КатегорииНоменклатуры ГДЕ НЕ ПометкаУдаления УПОРЯДОЧИТЬ ПО Наименование");
	Результат = Запрос.Выполнить().Выбрать();

	// Получаем сохранённый/дефолтный набор
	СохранённыеКатегории = ХранилищеОбщихНастроек.Загрузить("КНД_ЗагрузкаНакладныхСканер", "ВыбранныеКатегории");
	ДефолтныеИмена = Новый Массив;
	Если СохранённыеКатегории = Неопределено Тогда
		ДефолтныеИмена.Добавить("Продукты");
		ДефолтныеИмена.Добавить("Напитки");
		ДефолтныеИмена.Добавить("Дополнительно");
		ДефолтныеИмена.Добавить("Энергетики, вода");
	Иначе
		Для Каждого К Из СохранённыеКатегории Цикл
			ДефолтныеИмена.Добавить(К);
		КонецЦикла;
	КонецЕсли;

	КатегорииТаблица.Очистить();
	Пока Результат.Следующий() Цикл
		НоваяСтрока = КатегорииТаблица.Добавить();
		НоваяСтрока.Наименование = Результат.Наименование;
		// Предвыбрать если в дефолтных
		Для Каждого Имя Из ДефолтныеИмена Цикл
			Если Имя = Результат.Наименование Тогда
				НоваяСтрока.Пометка = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ЗаполнитьКатегорииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьНоменклатуру(Команда)
	// Старая кнопка теперь загружает список категорий из 1С.
	// Пользователь отмечает галочки и нажимает "Выгрузить выбранное".
	ЗаполнитьКатегорииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьВыбор(Команда)
	// Собираем отмеченные категории
	ВыбранныеИмена = Новый Массив;
	Для Каждого Строка Из КатегорииТаблица Цикл
		Если Строка.Пометка Тогда
			ВыбранныеИмена.Добавить(Строка.Наименование);
		КонецЕсли;
	КонецЦикла;

	Если ВыбранныеИмена.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Не выбрано ни одной категории");
		Возврат;
	КонецЕсли;

	Отчёт = ВыгрузитьНоменклатуруНаСервере(ВыбранныеИмена);
	ПоказатьПредупреждение(, Отчёт, 60);
КонецПроцедуры
