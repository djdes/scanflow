////////////////////////////////////////////////////////////////////////////////
// МОДУЛЬ ФОРМЫ: Загрузка накладных из JPGExchange
// Для 1С:УНФ 1.6
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    // Загрузить сохранённые настройки
    ЗагрузитьНастройки();

    // Значения по умолчанию
    Если ПустаяСтрока(Объект.АдресСервиса) Тогда
        Объект.АдресСервиса = "http://localhost:3000";
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
        // Попробовать установить организацию по умолчанию
        Объект.Организация = ПолучитьОрганизациюПоУмолчанию();
    КонецЕсли;

    Объект.СоздаватьНоменклатуру = Истина;
    Объект.ПроводитьДокументы = Ложь;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

    ДобавитьВЛог("Обработка запущена. Версия 1.0");
    ДобавитьВЛог("Адрес сервиса: " + Объект.АдресСервиса);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаЗагрузить(Команда)

    ОчиститьСообщения();

    // Проверка заполнения
    Если ПустаяСтрока(Объект.АдресСервиса) Тогда
        ПоказатьПредупреждение(, "Укажите адрес сервиса");
        Возврат;
    КонецЕсли;

    Если ПустаяСтрока(Объект.КлючAPI) Тогда
        ПоказатьПредупреждение(, "Укажите API-ключ");
        Возврат;
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
        ПоказатьПредупреждение(, "Выберите организацию");
        Возврат;
    КонецЕсли;

    ДобавитьВЛог("--- Начало загрузки накладных ---");
    ДобавитьВЛог("Время: " + Строка(ТекущаяДата()));

    // Выполнить загрузку на сервере
    Результат = ЗагрузитьНакладныеНаСервере(
        Объект.АдресСервиса,
        Объект.КлючAPI,
        Объект.Организация,
        Объект.Склад,
        Объект.СоздаватьНоменклатуру,
        Объект.ПроводитьДокументы
    );

    // Отобразить результат
    Если Результат.Успех Тогда
        ДобавитьВЛог("✓ " + Результат.Сообщение);

        Если Результат.ЗагруженоНакладных > 0 Тогда
            ДобавитьВЛог("Созданные документы:");
            Для Каждого ДокументСсылка Из Результат.СозданоДокументов Цикл
                ДобавитьВЛог("  - " + Строка(ДокументСсылка));
            КонецЦикла;
        КонецЕсли;

        ПоказатьОповещениеПользователя(
            "Загрузка завершена",
            ,
            Результат.Сообщение,
            БиблиотекаКартинок.Информация
        );
    Иначе
        ДобавитьВЛог("✗ Ошибка: " + Результат.Сообщение);
        ПоказатьПредупреждение(, Результат.Сообщение);
    КонецЕсли;

    ДобавитьВЛог("--- Загрузка завершена ---");
    ДобавитьВЛог("");

КонецПроцедуры

&НаКлиенте
Процедура КомандаПроверитьСоединение(Команда)

    ОчиститьСообщения();

    Если ПустаяСтрока(Объект.АдресСервиса) Тогда
        ПоказатьПредупреждение(, "Укажите адрес сервиса");
        Возврат;
    КонецЕсли;

    ДобавитьВЛог("Проверка соединения с " + Объект.АдресСервиса + "...");

    Результат = ПроверитьСоединениеНаСервере(Объект.АдресСервиса, Объект.КлючAPI);

    Если Результат.Успех Тогда
        ДобавитьВЛог("✓ " + Результат.Сообщение);
        ПоказатьОповещениеПользователя(
            "Соединение установлено",
            ,
            "Сервис доступен",
            БиблиотекаКартинок.Информация
        );
    Иначе
        ДобавитьВЛог("✗ Ошибка: " + Результат.Сообщение);
        ПоказатьПредупреждение(, "Ошибка соединения: " + Результат.Сообщение);
    КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура КомандаСохранитьНастройки(Команда)

    СохранитьНастройкиНаСервере();

    ПоказатьОповещениеПользователя(
        "Настройки сохранены",
        ,
        "Настройки успешно сохранены",
        БиблиотекаКартинок.Информация
    );

    ДобавитьВЛог("Настройки сохранены");

КонецПроцедуры

&НаКлиенте
Процедура КомандаОчиститьЛог(Команда)

    ПолеЛога = "";

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ДобавитьВЛог(Текст)

    Если НЕ ПустаяСтрока(ПолеЛога) Тогда
        ПолеЛога = ПолеЛога + Символы.ПС;
    КонецЕсли;

    ПолеЛога = ПолеЛога + "[" + Формат(ТекущаяДата(), "ДФ=HH:mm:ss") + "] " + Текст;

КонецПроцедуры

&НаСервере
Функция ЗагрузитьНакладныеНаСервере(АдресСервиса, КлючAPI, Организация, Склад,
    СоздаватьНоменклатуру, ПроводитьДокументы)

    // Вызов метода из модуля объекта
    Возврат РеквизитФормыВЗначение("Объект").ЗагрузитьНакладные(
        АдресСервиса,
        КлючAPI,
        Организация,
        Склад,
        СоздаватьНоменклатуру,
        ПроводитьДокументы
    );

КонецФункции

&НаСервере
Функция ПроверитьСоединениеНаСервере(АдресСервиса, КлючAPI)

    Возврат РеквизитФормыВЗначение("Объект").ПроверитьСоединение(АдресСервиса, КлючAPI);

КонецФункции

&НаСервере
Процедура СохранитьНастройкиНаСервере()

    // Сохранить настройки в хранилище общих настроек
    Попытка
        ХранилищеОбщихНастроек.Сохранить(
            "ЗагрузкаНакладныхJPGExchange",
            "АдресСервиса",
            Объект.АдресСервиса
        );

        ХранилищеОбщихНастроек.Сохранить(
            "ЗагрузкаНакладныхJPGExchange",
            "КлючAPI",
            Объект.КлючAPI
        );

        ХранилищеОбщихНастроек.Сохранить(
            "ЗагрузкаНакладныхJPGExchange",
            "Организация",
            Объект.Организация
        );

        ХранилищеОбщихНастроек.Сохранить(
            "ЗагрузкаНакладныхJPGExchange",
            "Склад",
            Объект.Склад
        );

    Исключение
        // Хранилище может быть недоступно
    КонецПопытки;

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьНастройки()

    Попытка
        Значение = ХранилищеОбщихНастроек.Загрузить(
            "ЗагрузкаНакладныхJPGExchange",
            "АдресСервиса"
        );
        Если Значение <> Неопределено Тогда
            Объект.АдресСервиса = Значение;
        КонецЕсли;

        Значение = ХранилищеОбщихНастроек.Загрузить(
            "ЗагрузкаНакладныхJPGExchange",
            "КлючAPI"
        );
        Если Значение <> Неопределено Тогда
            Объект.КлючAPI = Значение;
        КонецЕсли;

        Значение = ХранилищеОбщихНастроек.Загрузить(
            "ЗагрузкаНакладныхJPGExchange",
            "Организация"
        );
        Если Значение <> Неопределено Тогда
            Объект.Организация = Значение;
        КонецЕсли;

        Значение = ХранилищеОбщихНастроек.Загрузить(
            "ЗагрузкаНакладныхJPGExchange",
            "Склад"
        );
        Если Значение <> Неопределено Тогда
            Объект.Склад = Значение;
        КонецЕсли;

    Исключение
        // Игнорировать ошибки загрузки настроек
    КонецПопытки;

КонецПроцедуры

&НаСервере
Функция ПолучитьОрганизациюПоУмолчанию()

    // Попробовать получить единственную организацию
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |	Организации.Ссылка КАК Ссылка
        |ИЗ
        |	Справочник.Организации КАК Организации
        |ГДЕ
        |	НЕ Организации.ПометкаУдаления";

    Результат = Запрос.Выполнить();
    Если НЕ Результат.Пустой() Тогда
        Выборка = Результат.Выбрать();
        Выборка.Следующий();
        Возврат Выборка.Ссылка;
    КонецЕсли;

    Возврат Справочники.Организации.ПустаяСсылка();

КонецФункции

#КонецОбласти
