#Область ПрограммныйИнтерфейс

// Основная процедура загрузки накладных
//
// Параметры:
//  АдресСервиса - Строка - URL сервиса (например, http://localhost:3000)
//  КлючAPI - Строка - API-ключ для авторизации
//  Организация - СправочникСсылка.Организации - организация для документов
//  Склад - СправочникСсылка.Склады - склад поступления
//  СоздаватьНоменклатуру - Булево - создавать новую номенклатуру если не найдена
//  ПроводитьДокументы - Булево - проводить созданные документы
//
// Возвращаемое значение:
//  Структура - результат загрузки:
//   * Успех - Булево
//   * Сообщение - Строка
//   * ЗагруженоНакладных - Число
//   * СозданоДокументов - Массив ссылок на документы
//
Функция ЗагрузитьНакладные(АдресСервиса, КлючAPI, Организация, Склад,
    СоздаватьНоменклатуру = Истина, ПроводитьДокументы = Ложь) Экспорт

    Результат = Новый Структура;
    Результат.Вставить("Успех", Ложь);
    Результат.Вставить("Сообщение", "");
    Результат.Вставить("ЗагруженоНакладных", 0);
    Результат.Вставить("СозданоДокументов", Новый Массив);

    // Проверка параметров
    Если ПустаяСтрока(АдресСервиса) Тогда
        Результат.Сообщение = "Не указан адрес сервиса";
        Возврат Результат;
    КонецЕсли;

    Если ПустаяСтрока(КлючAPI) Тогда
        Результат.Сообщение = "Не указан API-ключ";
        Возврат Результат;
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(Организация) Тогда
        Результат.Сообщение = "Не выбрана организация";
        Возврат Результат;
    КонецЕсли;

    // 1. Получить список необработанных накладных
    СписокНакладных = ПолучитьСписокНакладных(АдресСервиса, КлючAPI);

    Если СписокНакладных = Неопределено Тогда
        Результат.Сообщение = "Ошибка получения списка накладных от сервиса";
        Возврат Результат;
    КонецЕсли;

    Если СписокНакладных.Количество() = 0 Тогда
        Результат.Успех = Истина;
        Результат.Сообщение = "Нет новых накладных для загрузки";
        Возврат Результат;
    КонецЕсли;

    // 2. Обработать каждую накладную
    Для Каждого ДанныеНакладной Из СписокНакладных Цикл

        Попытка
            // Получить полные данные накладной с товарами
            ПолныеДанные = ПолучитьДанныеНакладной(АдресСервиса, КлючAPI, ДанныеНакладной.id);

            Если ПолныеДанные = Неопределено Тогда
                Продолжить;
            КонецЕсли;

            // Создать документ
            СозданныйДокумент = СоздатьПриходнуюНакладную(
                ПолныеДанные,
                Организация,
                Склад,
                СоздаватьНоменклатуру,
                ПроводитьДокументы
            );

            Если СозданныйДокумент <> Неопределено Тогда
                // Подтвердить загрузку
                ПодтвердитьЗагрузку(АдресСервиса, КлючAPI, ДанныеНакладной.id);

                Результат.СозданоДокументов.Добавить(СозданныйДокумент);
                Результат.ЗагруженоНакладных = Результат.ЗагруженоНакладных + 1;
            КонецЕсли;

        Исключение
            // Логировать ошибку и продолжить
            ТекстОшибки = ОписаниеОшибки();
            Сообщить("Ошибка обработки накладной " + ДанныеНакладной.id + ": " + ТекстОшибки);
        КонецПопытки;

    КонецЦикла;

    Результат.Успех = Истина;
    Результат.Сообщение = "Загружено накладных: " + Результат.ЗагруженоНакладных;

    Возврат Результат;

КонецФункции

// Проверка соединения с сервисом
//
Функция ПроверитьСоединение(АдресСервиса, КлючAPI) Экспорт

    Попытка
        HTTPСоединение = СоздатьHTTPСоединение(АдресСервиса);
        Запрос = Новый HTTPЗапрос("/health");

        Ответ = HTTPСоединение.Получить(Запрос);

        Если Ответ.КодСостояния = 200 Тогда
            Возврат Новый Структура("Успех, Сообщение", Истина, "Соединение установлено");
        Иначе
            Возврат Новый Структура("Успех, Сообщение", Ложь, "Код ответа: " + Ответ.КодСостояния);
        КонецЕсли;

    Исключение
        Возврат Новый Структура("Успех, Сообщение", Ложь, ОписаниеОшибки());
    КонецПопытки;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Создание HTTP-соединения
//
Функция СоздатьHTTPСоединение(АдресСервиса)

    СтруктураURI = РазобратьURL(АдресСервиса);

    Если СтруктураURI.Схема = "https" Тогда
        Соединение = Новый HTTPСоединение(
            СтруктураURI.Хост,
            СтруктураURI.Порт,
            , , , ,
            Новый ЗащищенноеСоединениеOpenSSL()
        );
    Иначе
        Соединение = Новый HTTPСоединение(
            СтруктураURI.Хост,
            СтруктураURI.Порт
        );
    КонецЕсли;

    Возврат Соединение;

КонецФункции

// Разбор URL на компоненты
//
Функция РазобратьURL(URL)

    Результат = Новый Структура;
    Результат.Вставить("Схема", "http");
    Результат.Вставить("Хост", "localhost");
    Результат.Вставить("Порт", 80);

    РабочийURL = URL;

    // Определить схему
    Если СтрНачинаетсяС(НРег(РабочийURL), "https://") Тогда
        Результат.Схема = "https";
        Результат.Порт = 443;
        РабочийURL = Сред(РабочийURL, 9);
    ИначеЕсли СтрНачинаетсяС(НРег(РабочийURL), "http://") Тогда
        Результат.Схема = "http";
        Результат.Порт = 80;
        РабочийURL = Сред(РабочийURL, 8);
    КонецЕсли;

    // Убрать путь
    ПозицияСлеша = СтрНайти(РабочийURL, "/");
    Если ПозицияСлеша > 0 Тогда
        РабочийURL = Лев(РабочийURL, ПозицияСлеша - 1);
    КонецЕсли;

    // Определить порт
    ПозицияДвоеточия = СтрНайти(РабочийURL, ":");
    Если ПозицияДвоеточия > 0 Тогда
        Результат.Хост = Лев(РабочийURL, ПозицияДвоеточия - 1);
        Результат.Порт = Число(Сред(РабочийURL, ПозицияДвоеточия + 1));
    Иначе
        Результат.Хост = РабочийURL;
    КонецЕсли;

    Возврат Результат;

КонецФункции

// Получить список необработанных накладных
//
Функция ПолучитьСписокНакладных(АдресСервиса, КлючAPI)

    Попытка
        HTTPСоединение = СоздатьHTTPСоединение(АдресСервиса);

        Запрос = Новый HTTPЗапрос("/api/invoices/pending");
        Запрос.Заголовки.Вставить("X-API-Key", КлючAPI);
        Запрос.Заголовки.Вставить("Accept", "application/json");

        Ответ = HTTPСоединение.Получить(Запрос);

        Если Ответ.КодСостояния <> 200 Тогда
            Сообщить("Ошибка API: код " + Ответ.КодСостояния);
            Возврат Неопределено;
        КонецЕсли;

        ТелоОтвета = Ответ.ПолучитьТелоКакСтроку("UTF-8");

        // Парсинг JSON
        ЧтениеJSON = Новый ЧтениеJSON;
        ЧтениеJSON.УстановитьСтроку(ТелоОтвета);
        Данные = ПрочитатьJSON(ЧтениеJSON);
        ЧтениеJSON.Закрыть();

        // Ответ содержит { data: [...] }
        Если ТипЗнч(Данные) = Тип("Структура") И Данные.Свойство("data") Тогда
            Возврат Данные.data;
        КонецЕсли;

        Возврат Новый Массив;

    Исключение
        Сообщить("Ошибка получения списка накладных: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

// Получить полные данные накладной
//
Функция ПолучитьДанныеНакладной(АдресСервиса, КлючAPI, ИдНакладной)

    Попытка
        HTTPСоединение = СоздатьHTTPСоединение(АдресСервиса);

        Запрос = Новый HTTPЗапрос("/api/invoices/" + Формат(ИдНакладной, "ЧГ=0"));
        Запрос.Заголовки.Вставить("X-API-Key", КлючAPI);
        Запрос.Заголовки.Вставить("Accept", "application/json");

        Ответ = HTTPСоединение.Получить(Запрос);

        Если Ответ.КодСостояния <> 200 Тогда
            Возврат Неопределено;
        КонецЕсли;

        ТелоОтвета = Ответ.ПолучитьТелоКакСтроку("UTF-8");

        ЧтениеJSON = Новый ЧтениеJSON;
        ЧтениеJSON.УстановитьСтроку(ТелоОтвета);
        Данные = ПрочитатьJSON(ЧтениеJSON);
        ЧтениеJSON.Закрыть();

        Если ТипЗнч(Данные) = Тип("Структура") И Данные.Свойство("data") Тогда
            Возврат Данные.data;
        КонецЕсли;

        Возврат Данные;

    Исключение
        Сообщить("Ошибка получения данных накладной: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

// Подтвердить загрузку накладной
//
Процедура ПодтвердитьЗагрузку(АдресСервиса, КлючAPI, ИдНакладной)

    Попытка
        HTTPСоединение = СоздатьHTTPСоединение(АдресСервиса);

        Запрос = Новый HTTPЗапрос("/api/invoices/" + Формат(ИдНакладной, "ЧГ=0") + "/confirm");
        Запрос.Заголовки.Вставить("X-API-Key", КлючAPI);
        Запрос.Заголовки.Вставить("Content-Type", "application/json");
        Запрос.УстановитьТелоИзСтроки("{}", "UTF-8");

        Ответ = HTTPСоединение.ОтправитьДляОбработки(Запрос);

    Исключение
        Сообщить("Ошибка подтверждения загрузки: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры

// Создать документ Приходная накладная
//
Функция СоздатьПриходнуюНакладную(ДанныеНакладной, Организация, Склад,
    СоздаватьНоменклатуру, ПроводитьДокументы)

    // Найти или создать контрагента (по ИНН, если есть, иначе по имени)
    ИмяПоставщика = "";
    Если ДанныеНакладной.Свойство("supplier") И ЗначениеЗаполнено(ДанныеНакладной.supplier) Тогда
        ИмяПоставщика = ДанныеНакладной.supplier;
    КонецЕсли;

    ИННПоставщика = "";
    Если ДанныеНакладной.Свойство("supplier_inn") И ЗначениеЗаполнено(ДанныеНакладной.supplier_inn) Тогда
        ИННПоставщика = ДанныеНакладной.supplier_inn;
    КонецЕсли;

    Контрагент = НайтиИлиСоздатьКонтрагента(ИмяПоставщика, ИННПоставщика);

    Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
        Сообщить("Не удалось определить контрагента для накладной");
        Возврат Неопределено;
    КонецЕсли;

    // Определить дату накладной
    ДатаНакладной = ТекущаяДата();
    Если ДанныеНакладной.Свойство("invoice_date") И ЗначениеЗаполнено(ДанныеНакладной.invoice_date) Тогда
        Попытка
            // Формат даты: YYYY-MM-DD
            СтрДата = ДанныеНакладной.invoice_date;
            ДатаНакладной = Дата(
                Число(Лев(СтрДата, 4)),       // Год
                Число(Сред(СтрДата, 6, 2)),   // Месяц
                Число(Сред(СтрДата, 9, 2))    // День
            );
        Исключение
            ДатаНакладной = ТекущаяДата();
        КонецПопытки;
    КонецЕсли;

    // Создать документ
    // ВАЖНО: Имя документа может отличаться в разных конфигурациях УНФ
    // Возможные варианты: ПриходнаяНакладная, ПоступлениеТоваровУслуг, ПоступлениеЗапасов

    НовыйДокумент = Неопределено;

    // Попробовать найти подходящий тип документа
    Попытка
        НовыйДокумент = Документы.ПриходнаяНакладная.СоздатьДокумент();
    Исключение
        Попытка
            НовыйДокумент = Документы.ПоступлениеТоваровУслуг.СоздатьДокумент();
        Исключение
            Попытка
                НовыйДокумент = Документы.ПоступлениеЗапасов.СоздатьДокумент();
            Исключение
                Сообщить("Не найден подходящий тип документа поступления");
                Возврат Неопределено;
            КонецПопытки;
        КонецПопытки;
    КонецПопытки;

    // Заполнить шапку документа
    НовыйДокумент.Дата = ДатаНакладной;
    НовыйДокумент.Организация = Организация;
    НовыйДокумент.Контрагент = Контрагент;

    // Договор — всегда "Основной договор"
    Попытка
        Договор = НайтиОсновнойДоговор(Контрагент, Организация);
        Если ЗначениеЗаполнено(Договор) Тогда
            // В УНФ реквизит может называться "Договор" или "ДоговорКонтрагента"
            Попытка
                НовыйДокумент.Договор = Договор;
            Исключение
                Попытка
                    НовыйДокумент.ДоговорКонтрагента = Договор;
                Исключение
                КонецПопытки;
            КонецПопытки;
        КонецЕсли;
    Исключение
        // Реквизит может отсутствовать
    КонецПопытки;

    // Номер входящего документа
    Если ДанныеНакладной.Свойство("invoice_number") Тогда
        Попытка
            НовыйДокумент.НомерВходящегоДокумента = ДанныеНакладной.invoice_number;
        Исключение
            // Реквизит может отсутствовать
        КонецПопытки;
    КонецЕсли;

    // Склад (если есть такой реквизит)
    Если ЗначениеЗаполнено(Склад) Тогда
        Попытка
            НовыйДокумент.Склад = Склад;
        Исключение
            // Реквизит может отсутствовать
        КонецПопытки;
    КонецЕсли;

    // Заполнить табличную часть товарами
    Товары = Неопределено;
    Если ДанныеНакладной.Свойство("items") Тогда
        Товары = ДанныеНакладной.items;
    КонецЕсли;

    Если Товары <> Неопределено И ТипЗнч(Товары) = Тип("Массив") Тогда

        // Определить имя табличной части
        ИмяТабличнойЧасти = ОпределитьИмяТабличнойЧасти(НовыйДокумент);

        Для Каждого Товар Из Товары Цикл

            // Найти или создать номенклатуру
            ИмяНоменклатуры = "";
            Если Товар.Свойство("mapped_name") И ЗначениеЗаполнено(Товар.mapped_name) Тогда
                ИмяНоменклатуры = Товар.mapped_name;
            ИначеЕсли Товар.Свойство("original_name") Тогда
                ИмяНоменклатуры = Товар.original_name;
            Иначе
                Продолжить;
            КонецЕсли;

            Номенклатура = НайтиИлиСоздатьНоменклатуру(ИмяНоменклатуры, СоздаватьНоменклатуру);

            Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
                Сообщить("Номенклатура не найдена: " + ИмяНоменклатуры);
                Продолжить;
            КонецЕсли;

            // Добавить строку в табличную часть
            НоваяСтрока = Неопределено;

            Если ИмяТабличнойЧасти = "Запасы" Тогда
                НоваяСтрока = НовыйДокумент.Запасы.Добавить();
            ИначеЕсли ИмяТабличнойЧасти = "Товары" Тогда
                НоваяСтрока = НовыйДокумент.Товары.Добавить();
            ИначеЕсли ИмяТабличнойЧасти = "ТоварыУслуги" Тогда
                НоваяСтрока = НовыйДокумент.ТоварыУслуги.Добавить();
            Иначе
                Продолжить;
            КонецЕсли;

            НоваяСтрока.Номенклатура = Номенклатура;

            // Количество
            Если Товар.Свойство("quantity") И ЗначениеЗаполнено(Товар.quantity) Тогда
                НоваяСтрока.Количество = Товар.quantity;
            Иначе
                НоваяСтрока.Количество = 1;
            КонецЕсли;

            // Цена
            Если Товар.Свойство("price") И ЗначениеЗаполнено(Товар.price) Тогда
                НоваяСтрока.Цена = Товар.price;
            КонецЕсли;

            // Сумма
            Если Товар.Свойство("total") И ЗначениеЗаполнено(Товар.total) Тогда
                НоваяСтрока.Сумма = Товар.total;
            Иначе
                НоваяСтрока.Сумма = НоваяСтрока.Количество * НоваяСтрока.Цена;
            КонецЕсли;

            // Единица измерения (если есть)
            Попытка
                Если Товар.Свойство("unit") И ЗначениеЗаполнено(Товар.unit) Тогда
                    ЕдИзм = НайтиЕдиницуИзмерения(Товар.unit);
                    Если ЗначениеЗаполнено(ЕдИзм) Тогда
                        НоваяСтрока.ЕдиницаИзмерения = ЕдИзм;
                    КонецЕсли;
                КонецЕсли;
            Исключение
                // Реквизит может отсутствовать
            КонецПопытки;

        КонецЦикла;

    КонецЕсли;

    // Записать документ
    Попытка
        Если ПроводитьДокументы Тогда
            НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
        Иначе
            НовыйДокумент.Записать();
        КонецЕсли;

        Возврат НовыйДокумент.Ссылка;

    Исключение
        Сообщить("Ошибка записи документа: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

// Определить имя табличной части документа
//
Функция ОпределитьИмяТабличнойЧасти(Документ)

    МетаданныеДокумента = Документ.Метаданные();

    Для Каждого ТЧ Из МетаданныеДокумента.ТабличныеЧасти Цикл
        Если ТЧ.Имя = "Запасы" Тогда
            Возврат "Запасы";
        ИначеЕсли ТЧ.Имя = "Товары" Тогда
            Возврат "Товары";
        ИначеЕсли ТЧ.Имя = "ТоварыУслуги" Тогда
            Возврат "ТоварыУслуги";
        КонецЕсли;
    КонецЦикла;

    // Вернуть первую табличную часть
    Для Каждого ТЧ Из МетаданныеДокумента.ТабличныеЧасти Цикл
        Возврат ТЧ.Имя;
    КонецЦикла;

    Возврат "";

КонецФункции

// Найти или создать контрагента
//
// Параметры:
//  ИмяКонтрагента - Строка - наименование
//  ИНН - Строка - ИНН (опционально, даёт более надёжный поиск)
//
Функция НайтиИлиСоздатьКонтрагента(ИмяКонтрагента, ИНН = "")

    Если ПустаяСтрока(ИмяКонтрагента) И ПустаяСтрока(ИНН) Тогда
        Возврат Справочники.Контрагенты.ПустаяСсылка();
    КонецЕсли;

    // 1. Если есть ИНН — искать по ИНН (самый надёжный способ)
    Если НЕ ПустаяСтрока(ИНН) Тогда
        Попытка
            Запрос = Новый Запрос;
            Запрос.Текст =
                "ВЫБРАТЬ ПЕРВЫЕ 1
                |	Контрагенты.Ссылка КАК Ссылка
                |ИЗ
                |	Справочник.Контрагенты КАК Контрагенты
                |ГДЕ
                |	Контрагенты.ИНН = &ИНН
                |	И НЕ Контрагенты.ПометкаУдаления";
            Запрос.УстановитьПараметр("ИНН", ИНН);

            Результат = Запрос.Выполнить();
            Если НЕ Результат.Пустой() Тогда
                Выборка = Результат.Выбрать();
                Выборка.Следующий();
                Возврат Выборка.Ссылка;
            КонецЕсли;
        Исключение
            // Реквизит ИНН может отсутствовать в этой конфигурации — игнорируем
        КонецПопытки;
    КонецЕсли;

    // 2. Поиск по точному наименованию
    Если НЕ ПустаяСтрока(ИмяКонтрагента) Тогда
        Контрагент = Справочники.Контрагенты.НайтиПоНаименованию(ИмяКонтрагента, Истина);
        Если ЗначениеЗаполнено(Контрагент) Тогда
            Возврат Контрагент;
        КонецЕсли;
    КонецЕсли;

    // 3. Нечёткий поиск по части наименования
    Если НЕ ПустаяСтрока(ИмяКонтрагента) Тогда
        ОчищенноеИмя = ОчиститьНаименованиеКонтрагента(ИмяКонтрагента);

        Запрос = Новый Запрос;
        Запрос.Текст =
            "ВЫБРАТЬ ПЕРВЫЕ 1
            |	Контрагенты.Ссылка КАК Ссылка
            |ИЗ
            |	Справочник.Контрагенты КАК Контрагенты
            |ГДЕ
            |	Контрагенты.Наименование ПОДОБНО &Имя
            |	И НЕ Контрагенты.ПометкаУдаления";

        Запрос.УстановитьПараметр("Имя", "%" + ОчищенноеИмя + "%");

        Результат = Запрос.Выполнить();
        Если НЕ Результат.Пустой() Тогда
            Выборка = Результат.Выбрать();
            Выборка.Следующий();
            Возврат Выборка.Ссылка;
        КонецЕсли;
    КонецЕсли;

    // 4. Не нашли — создать нового контрагента
    НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
    НовыйКонтрагент.Наименование = ИмяКонтрагента;

    // Установить ИНН, если есть
    Если НЕ ПустаяСтрока(ИНН) Тогда
        Попытка
            НовыйКонтрагент.ИНН = ИНН;
        Исключение
            // Реквизит может отсутствовать
        КонецПопытки;
    КонецЕсли;

    // Определить тип контрагента
    Попытка
        Если СтрНачинаетсяС(ВРег(ИмяКонтрагента), "ИП ") Тогда
            НовыйКонтрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
        Иначе
            НовыйКонтрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
        КонецЕсли;
    Исключение
        // Перечисление может отсутствовать
    КонецПопытки;

    // Установить вид контрагента - Поставщик
    Попытка
        НовыйКонтрагент.Поставщик = Истина;
    Исключение
        // Реквизит может отсутствовать
    КонецПопытки;

    Попытка
        НовыйКонтрагент.Записать();
        Возврат НовыйКонтрагент.Ссылка;
    Исключение
        Сообщить("Ошибка создания контрагента: " + ОписаниеОшибки());
        Возврат Справочники.Контрагенты.ПустаяСсылка();
    КонецПопытки;

КонецФункции

// Очистить наименование контрагента для поиска
//
Функция ОчиститьНаименованиеКонтрагента(Имя)

    Результат = Имя;

    // Убрать кавычки
    Результат = СтрЗаменить(Результат, """", "");
    Результат = СтрЗаменить(Результат, "«", "");
    Результат = СтрЗаменить(Результат, "»", "");

    // Убрать организационно-правовую форму
    Результат = СтрЗаменить(ВРег(Результат), "ООО ", "");
    Результат = СтрЗаменить(Результат, "ОАО ", "");
    Результат = СтрЗаменить(Результат, "ЗАО ", "");
    Результат = СтрЗаменить(Результат, "АО ", "");
    Результат = СтрЗаменить(Результат, "ПАО ", "");
    Результат = СтрЗаменить(Результат, "ИП ", "");

    Возврат СокрЛП(Результат);

КонецФункции

// Найти или создать номенклатуру
//
Функция НайтиИлиСоздатьНоменклатуру(ИмяНоменклатуры, СоздаватьНовую = Истина)

    Если ПустаяСтрока(ИмяНоменклатуры) Тогда
        Возврат Справочники.Номенклатура.ПустаяСсылка();
    КонецЕсли;

    // Поиск по точному наименованию
    Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(ИмяНоменклатуры, Истина);

    Если ЗначениеЗаполнено(Номенклатура) Тогда
        Возврат Номенклатура;
    КонецЕсли;

    // Поиск по части наименования
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |	Номенклатура.Ссылка КАК Ссылка
        |ИЗ
        |	Справочник.Номенклатура КАК Номенклатура
        |ГДЕ
        |	Номенклатура.Наименование ПОДОБНО &Имя
        |	И НЕ Номенклатура.ПометкаУдаления
        |	И НЕ Номенклатура.ЭтоГруппа";

    Запрос.УстановитьПараметр("Имя", "%" + Лев(ИмяНоменклатуры, 50) + "%");

    Результат = Запрос.Выполнить();
    Если НЕ Результат.Пустой() Тогда
        Выборка = Результат.Выбрать();
        Выборка.Следующий();
        Возврат Выборка.Ссылка;
    КонецЕсли;

    // Создать новую номенклатуру
    Если СоздаватьНовую Тогда

        НоваяНоменклатура = Справочники.Номенклатура.СоздатьЭлемент();
        НоваяНоменклатура.Наименование = Лев(ИмяНоменклатуры, 150);

        // Установить тип номенклатуры - Товар
        Попытка
            НоваяНоменклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас;
        Исключение
            Попытка
                НоваяНоменклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Товар;
            Исключение
                // Перечисление может отсутствовать или иметь другие значения
            КонецПопытки;
        КонецПопытки;

        // Установить базовую единицу измерения
        Попытка
            ЕдИзмШт = Справочники.ЕдиницыИзмерения.НайтиПоНаименованию("шт", Истина);
            Если ЗначениеЗаполнено(ЕдИзмШт) Тогда
                НоваяНоменклатура.ЕдиницаИзмерения = ЕдИзмШт;
            КонецЕсли;
        Исключение
            // Справочник может отсутствовать
        КонецПопытки;

        Попытка
            НоваяНоменклатура.Записать();
            Возврат НоваяНоменклатура.Ссылка;
        Исключение
            Сообщить("Ошибка создания номенклатуры: " + ОписаниеОшибки());
            Возврат Справочники.Номенклатура.ПустаяСсылка();
        КонецПопытки;

    КонецЕсли;

    Возврат Справочники.Номенклатура.ПустаяСсылка();

КонецФункции

// Найти единицу измерения
//
Функция НайтиЕдиницуИзмерения(КодЕдиницы)

    СоответствиеЕдиниц = Новый Соответствие;
    СоответствиеЕдиниц.Вставить("шт", "шт");
    СоответствиеЕдиниц.Вставить("кг", "кг");
    СоответствиеЕдиниц.Вставить("л", "л");
    СоответствиеЕдиниц.Вставить("уп", "уп");
    СоответствиеЕдиниц.Вставить("упак", "уп");
    СоответствиеЕдиниц.Вставить("пач", "пач");
    СоответствиеЕдиниц.Вставить("бут", "бут");

    ИмяЕдиницы = СоответствиеЕдиниц.Получить(НРег(КодЕдиницы));
    Если ИмяЕдиницы = Неопределено Тогда
        ИмяЕдиницы = КодЕдиницы;
    КонецЕсли;

    Попытка
        Возврат Справочники.ЕдиницыИзмерения.НайтиПоНаименованию(ИмяЕдиницы, Истина);
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

// Найти "Основной договор" для контрагента
//
Функция НайтиОсновнойДоговор(Контрагент, Организация)

    Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
        Возврат Неопределено;
    КонецЕсли;

    // Поиск по наименованию "Основной договор" для данного контрагента
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |    Договоры.Ссылка КАК Ссылка
        |ИЗ
        |    Справочник.ДоговорыКонтрагентов КАК Договоры
        |ГДЕ
        |    Договоры.Владелец = &Контрагент
        |    И Договоры.Наименование ПОДОБНО ""%Основной%""
        |    И НЕ Договоры.ПометкаУдаления";

    Запрос.УстановитьПараметр("Контрагент", Контрагент);

    Результат = Запрос.Выполнить();
    Если НЕ Результат.Пустой() Тогда
        Выборка = Результат.Выбрать();
        Выборка.Следующий();
        Возврат Выборка.Ссылка;
    КонецЕсли;

    // Если не найден — взять первый договор контрагента
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |    Договоры.Ссылка КАК Ссылка
        |ИЗ
        |    Справочник.ДоговорыКонтрагентов КАК Договоры
        |ГДЕ
        |    Договоры.Владелец = &Контрагент
        |    И НЕ Договоры.ПометкаУдаления";

    Результат = Запрос.Выполнить();
    Если НЕ Результат.Пустой() Тогда
        Выборка = Результат.Выбрать();
        Выборка.Следующий();
        Возврат Выборка.Ссылка;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

#КонецОбласти
